      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="GIS-350-243 Ignore action for factor: (see GIS-350-903) list of nodes representing partial actions in the action tree, for which the action tree factor (GIS-350-241) is not increased by 1" Name="Ignoreactionforfactor" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
