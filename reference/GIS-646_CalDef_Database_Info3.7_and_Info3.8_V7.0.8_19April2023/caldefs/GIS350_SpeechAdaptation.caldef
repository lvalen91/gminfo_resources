<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Description="Enable frequency of task adaptive feature for MY 18. ">
  <CalDefFileVersion>7</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>22APR14</Date>
    <Description></Description>
    <Author>Robert Sims</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>29SEP14</Date>
    <Description>Added Usage on MID and HIGH</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>10Feb15</Date>
    <Description>Changes for GIS 350 Version 1.2</Description>
    <Author>Ute Winter</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>6/18/2015</Date>
    <Description>Changes: Cal parameter DisambiguationFlag deleted; cal parameter Domainnumberoftasks type changed from integer to EnumIntegerMap and linked to enumdef; cal parameter FCtaskdatabound type changed from interger to float; cal paramter Expertisetimewindows linked to enumdef; cal paramter Ignoreactionforfactor changed from EnumIntegerMap to Enumeration and linked to enumdef; added usage type to the Expertisetimewindows CAL all paramter values set to 65% BOR cal overrides  </Description>
    <Author>Ute Winter</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>3/4/2016</Date>
    <Description>Enable adaptive feature Frequency of Task for MY 18 and adjust cals according to performance test results. Change cal IgnoreFactorForAction from Enumeration to EnumIntegerMap</Description>
    <Author>Ute Winter, Xufang Zhao</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>6/14/2017</Date>
    <Description>Updated the usage field for all of the calibration in this caldef file to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="GIS 350-207 Holds a non-negative value to weight the task preference of a user for each distinguished task by the typical context it is usually requested from the HMI/Speech system. It weights the final prior probability of a task to be optimally balanced between the context prior probability and the general prior probability:" Name="ContextualWeightFactor" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_ySyh4MYiEeO1w62ps1mvqw</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <Integer>
      <Value>0</Value>
      <MinValue>0</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="GIS-350-208 Absolute disambiguation threshold: see GIS-350-1205) Constant value Dabs, as threshold for confidence scores in disambiguation lists. A disambiguation list may be rank ordered if the entry with the highest confidence score C1 exceeds Dabs : C1 > Dabs" Name="AbsoluteDisambiguationThreshold" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_EVkK0MYjEeO1w62ps1mvqw</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <Integer>
      <Value>0</Value>
      <MinValue>0</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="GIS-350-209 Delta disambiguation threshold: (see GIS-350-1205) Constant value Ddelta, referring to the distance between the two highest confidence scores C1 and C2 in disambiguation lists. A disambiguation list may be ranked ordered if this distance exceeds Dabs: C1  &#xf02d; C2 > Ddelta." Name="DeltaDisambiguationThreshold" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_OMlTQMYjEeO1w62ps1mvqw</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <Integer>
      <Value>0</Value>
      <MinValue>0</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="GIS-350-246 User model threshold: (see GIS-350-902) real or natural number in the range of the speech systems confidence scores. The threshold allows all tasks with confidence scores below to enter the User Model only under specified conditions to prevent falsely accepted tasks to enter the user Model." Name="Usermodelthreshold" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_IeIT4Kn6EeSUBfpqmsgk4g</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <Integer>
      <Value>6000</Value>
      <MinValue>-2147483648</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
