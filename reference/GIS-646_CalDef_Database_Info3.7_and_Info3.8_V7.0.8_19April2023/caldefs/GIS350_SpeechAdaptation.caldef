      <Resolution>1.0</Resolution>
      <ArrayValue>3000</ArrayValue>
      <ArrayValue>8000</ArrayValue>
    </IntegerArray>
  </CalDefinition>
  <CalDefinition Description="GIS-350-245 Action no score decrease: (see GIS-350-1203) list of actions for which original confidence score are not replaced by scores after adaptation if this leads to a decrease in the score. The original score is only replaced if this leads to an increase in the score. The value of this parameter may be &#x201c;all&#x201d; actions" Name="Actionnoscoredecrease" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
