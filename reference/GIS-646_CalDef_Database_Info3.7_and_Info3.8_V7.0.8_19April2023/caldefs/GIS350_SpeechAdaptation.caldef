  <CalDefinition Description="GIS-350-241 Minimum task for prior: (see GIS-350-1309) natural number as a threshold for a minimum of observed task data to estimate reliable and representative prior probabilities in the User Model. Below this threshold each prior probability is lowered by a reward weight factor Wp" Name="Minimumtaskforprior" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_XliycMY-EeOpjZKz3hOPiA</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <Integer>
      <Value>10000</Value>
      <MinValue>0</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="GIS-350-242 Action tree factor: (see GIS-350-903) natural number n and constant natural number f_act as a weight factor f_act^n in the action tree to normalize the absolute counts of all actions regarding their position in the tree" Name="Actiontreefactor" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_qZO68MY-EeOpjZKz3hOPiA</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <Integer>
