<?xml version="1.0" encoding="UTF-8"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Description="The Vehicle Specific Equalization (VSE) feature shall be implemented within the CSM’s AudioProcessor for the Internal Amplified Configuration 1.  VSE provides custom audio equalization to compensate for the acoustical uniqueness of different vehicle speakers/interiors on systems without a custom remote amplifier.  The requirements in this section define seven customizable filters for each of the four amplified speaker outputs.  The coefficient values for all filters shall be calibrateable within the CSM.  NOTE:  These calibrations are to be used if the CalDef format is chosen for VSE and not a proprietary calibration scheme for VSE.  V1.0 - Initial Release">
  <CalDefFileVersion>8</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>17APR14</Date>
    <Description>Reviewed for compliance to CalDef Guidelines. - Jon G</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>29SEP14</Date>
    <Description>Added Usage on LOW, MID, and HIGH</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>31OCT14</Date>
    <Description>Updated to add High Pass Order and High Pass Q factor based on FTCA Low radio issue index 980/981.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>02APR2015</Date>
    <Description>Two Changes:  1)  Updated Resolution of all 28 VSE_PARAM_EQ_BOOST_CUT cals from 0.5 dB to 0.1 dB.  2)  Added 12 new cals:  VSE_PARAM_EQ_FUNCTION_BAND_X_QQ for updates to GIS-604 v1.5.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>1/27/16</Date>
    <Description>Addition of LGE requested tuning calibration to support Arkamys Tuning factors.  VOL_SCAL_F, VOL_SCAL_R, VOL_UPSCAL_F, VOL_UPSCAL_R, Delay_Length1_In, Delay_Length2_In, Delay_Length3_In, Delay_Length4_In, Delay_InitFlag  </Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>6/15/2017</Date>
    <Description>Updated the usage field for all of the calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>10/2/2017</Date>
    <Description>Within the VehicleSpecificEqualization.caldef file, added GEM usage to all of the calibrations within this caldef. Since all of these calibrations fell within the current criteria of requiring GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>8</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>9</Version>
    <Date>6/7/2019</Date>
    <Description>Per CR#2060763 AOSP transition, Remove VCU usage for all calibrations.</Description>
    <Author>Christine Marzan</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="The AudioProcessor shall implement an independent high-pass shelf filter on each of the four audio outputs." Name="VSE_LF_HIGH_PASS_ORDER" References="GIS-604-420" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
