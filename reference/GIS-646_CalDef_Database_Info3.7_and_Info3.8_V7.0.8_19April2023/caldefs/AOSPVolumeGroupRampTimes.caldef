    <CalID>_OJTQ4Y7BEem6S5_uwl3E0g</CalID>
    <Type>Enumeration</Type>
    <Version>1</Version>
    <Enumeration>
      <EnumID>_EIFYsGX2EeSy4KUHhd_sAg</EnumID>
      <Value>1</Value>
    </Enumeration>
  </CalDefinition>
