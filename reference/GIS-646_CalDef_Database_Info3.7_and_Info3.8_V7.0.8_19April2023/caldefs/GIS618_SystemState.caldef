  </CalDefinition>
  <CalDefinition Description="This calibration shall define the Timeout value used to monitor Suspend-To-RAM execution. Upon Timeout VIP will continue Suspend operation ignoring the SuspensionCompletion ACK from the SOC." Name="SUSPEND_TIME" References="TBD" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_frBNIKL1EeeKqKPvPjizjg</CalID>
    <Type>Integer</Type>
