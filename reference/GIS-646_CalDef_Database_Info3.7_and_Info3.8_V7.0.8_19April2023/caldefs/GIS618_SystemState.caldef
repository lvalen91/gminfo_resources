      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>30</Value>
      <MinValue>0</MinValue>
      <MaxValue>120</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration shall define the Timeout value used to force Infotainment Power Mode to change from LAST_KNOWN Vehicle Power Mode to Off in the event of Power Mode Master and Backup Power Mode Master failure." Name="POWERMODE_FAILURE_TIMEOUT" References="GIS-618-535" Usage="LOW,MID,HIGH,GEM,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_Es-7sJ8LEeeKqKPvPjizjg</CalID>
