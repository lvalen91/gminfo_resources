    </CalDefChangeRecord>
    <Integer>
      <Value>10</Value>
      <MinValue>10</MinValue>
      <MaxValue>60</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration shall define the maximum length of time for a flush cycle to complete before a failsoft full shutdown is performed. It is implemented by the internal PowerLifeCycle state machine." Name="MAXIMUM_FLUSH_FAULT_TIME" References="GIS-618-520" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_ivZ-kJ7sEeeKqKPvPjizjg</CalID>
