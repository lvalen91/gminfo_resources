      <MaxValue>10</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration shall define the Timeout value used to monitor Resume status. Started upon starting to resume SOC, and stop upon receiving power level 3 message as Resumption Success ACK. Upon timeout VIP will reset the whole system as SOC failed to resume.  It is implemented by the internal PowerLifeCycle state machine." Name="RESUME_FAULT_TIMEOUT" References="PLC" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_rukMoKL3EeeKqKPvPjizjg</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
