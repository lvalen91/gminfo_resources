  <CalDefinition Description="Used to define trigger condition for exiting LocalInfotainment." Name="LOCAL_INFOTAINMENT_CANCEL_MODE" References="GIS-618-420" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_sruYELmzEeONt_iAU7Ji9A</CalID>
