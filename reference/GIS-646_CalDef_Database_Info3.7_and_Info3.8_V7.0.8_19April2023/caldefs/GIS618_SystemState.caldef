  <CalDefinition Description="This calibration shall define the timeout value used to assure that upon timer expiration there is no Infotainment activity for the CSM to support and the Infotainment System is now ready to shut down." Name="INFOTAINMENT_ACTIVITY_TIMEOUT" References="GIS-618-536" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_GlteEJ7uEeeKqKPvPjizjg</CalID>
