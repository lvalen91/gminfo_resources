    </CalDefChangeRecord>
    <Integer>
      <Value>36000</Value>
      <MinValue>10800</MinValue>
      <MaxValue>97200</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
