    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>9/20/2017</Date>
      <Description>Cal Description Only Update for additional clarity</Description>
      <Author>Younus Syed</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>86400</Value>
      <MinValue>0</MinValue>
      <MaxValue>244800</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Maximum allowed time for Resume from Suspended state before the SSTL logic takes failsoft action and resets the main SOC." Name="MAXIMUM_RESUME_TIME" References="GIS-618-520" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
