    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration shall define the Timeout value used to monitor Suspend-To-RAM preparation. Upon Timeout VIP will send SUSPEND_P2 request to SOC to start next level of suspension." Name="SUSPEND_PREPARATION_TIMEOUT" References="PLC" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_jwMdUKL2EeeKqKPvPjizjg</CalID>
