      <MaxValue>4000</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This is the maximum cumulative time in 'Hours' during which the ECU remains in PowerMode On&#xa0;state,&#xa0;across ignition cycles, between periods for which it is suspended, before a&#xa0;Shutdown-with-Reset request is sent to the PLC State Controller." Name="FLUSH_LIMIT_TIME" References="FG.04.03-2.2.26" Usage="MID,HIGH,VCU,GLOBALB">
