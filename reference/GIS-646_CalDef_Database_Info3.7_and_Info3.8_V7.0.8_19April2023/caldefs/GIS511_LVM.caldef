    <Enumeration>
      <EnumID>_QGGO8EIVEeW1KJbfjB0QJg</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="Each LVM application has a specific ID which is programmed in the LVM's non-volatile memory according to the features supported.  This parameter, known as the LVMApplicationID, is used by the CSM to notify the LVM(s) of which LVM application is currently in use.  The CSM requires an End of Line calibration providing details of which LVM applications are supported.  " Name="LVM_1" References="GIS-511" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
