  <CalDefinition Description="May have the ability to enable/disable Teen Driver Mode" Name="TeenDriverEnableDisable" References="Gis507 5.1.1.1*MY17 Calibration Items" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
