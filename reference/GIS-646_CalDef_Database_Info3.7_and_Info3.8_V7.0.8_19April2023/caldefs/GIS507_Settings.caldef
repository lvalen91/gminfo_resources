  <CalDefinition Description="In the Audio Feedback Speed settings menu, the user is presented with the options Slow, Medium, and Fast. These settings correlate to the following iTextToSpeech SpeechRate values: Slow = 75% Medium = 100% Fast= 125%" Name="Audio_Feedback_Speed_settings_iText_To_Speech_Speech_Rates_Values" References="Gis507 5.1.1.1*MY17 Calibration Items" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_6k8GAG7eEeSssq_awwoZ3g</CalID>
