      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The RDS_Radio_Menu_Item_On determines the HMI menu default state (RDS Info On/Off) when RDS is active in the tuner.  If RDS is not active in the tuner, this calibration is not used.  The default state for this calibration is TRUE (On).  This means the HMI menu item default setting for RDS is &quot;ON&quot; and RDS information is displayed for the currently tuned station.  When set to OFF, RDS information is not displayed for the currently tuned station." Name="RDS_Radio_Menu_Item_On" References="GIS-502 6.1.1.1" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_w-9rwLlEEeSMLcx9-dghJQ</CalID>
