  <CalDefinition Description="This calibration determines if the DAB source mode icon will be displayed as a source in the radio screen.  The default value is FALSE which means do not display the Source Mode icon." Name="DAB_Source_Mode" References="GIS-502 4.1.3.4" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_EyCukd09EeSvBMdbuIN9qg</CalID>
    <Type>Boolean</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
