      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="The Metadata_Paging_Rate calibration controls the paging rate of metadata when the metadata does not fit within the defined HMI metadata field size.  The default value is 5 seconds.  This means when paged metadata is available, each page displays for 5 seconds before moving to the next page of metadata." Name="Metadata_Paging_Rate" References="GIS-502 4.1.3" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_BhMVsblKEeSMLcx9-dghJQ</CalID>
