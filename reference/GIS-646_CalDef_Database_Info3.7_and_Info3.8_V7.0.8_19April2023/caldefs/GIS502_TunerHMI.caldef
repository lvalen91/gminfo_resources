    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/1/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="This calibration is required to support RDS regulatory requirements in certain markets. The RDS_PTY_Menu_Item_On determines the HMI menu default state (RDS PTY On/Off) when FM_RDS_PTY_enabled is activated in the tuner. If FM_RDS_PTY_enabled is not active in the tuner, the state of this calibration shall be set to FALSE. The default state for this calibration is FALSE(Off). This means the HMI menu item default setting for RDS PTY is &quot;OFF&quot; and the user will not see RDS PTY (categories) information. When the cal is TRUE (ON), RDS PTY (categories) will be displayed." Name="RDS_PTY_Menu_Item_On" References="" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_B5zXYJKhEem0sOY-d8MlZA</CalID>
