  <CalDefinition Description="For the enumerated value selected, the feature is locked out when the enumerated state is TRUE and for     enumerated states greater that the selected default." Name="VideoLockOut" References="GIS-502-6.4" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
