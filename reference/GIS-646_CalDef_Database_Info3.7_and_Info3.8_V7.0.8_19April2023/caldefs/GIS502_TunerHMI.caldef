      <Author>Christine Marzan</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="The Region_Setting_Menu_Item_On determines the HMI menu default state (Region Setting On or Off) for markets that support this FM feature. The default state for this calibration is TRUE (On).  This means the HMI menu item default setting for Region setting is On and the tuner shall support Region switching where available.  When set to OFF, Region switching will not be active in the tuner even in areas that support the feature." Name="Region_Setting_Menu_Item_On" References="GIS-502-4.1.28.2" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
