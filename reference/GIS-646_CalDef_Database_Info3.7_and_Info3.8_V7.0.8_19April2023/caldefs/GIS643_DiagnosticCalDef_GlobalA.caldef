    <Integer>
      <Value>9</Value>
      <MinValue>9</MinValue>
      <MaxValue>16</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="TODO - Add a description" Name="DTC_IGN_CYCLE_CTR_MAX" References="" Usage="LOW,GLOBALA,ENTRY_VCU">
