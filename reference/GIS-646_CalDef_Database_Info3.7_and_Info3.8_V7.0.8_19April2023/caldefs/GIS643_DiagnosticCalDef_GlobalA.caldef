  <CalDefinition Description="B124F_42_APPLICATION DOWNLOAD PERFORMANCE. Calibration Data Set not Programmed - This sub type is used to indicate that operational software is present but calibration data is not." Name="DTC_MASK_B124F_42" References="" Usage="LOW,GLOBALA,ENTRY_VCU">
