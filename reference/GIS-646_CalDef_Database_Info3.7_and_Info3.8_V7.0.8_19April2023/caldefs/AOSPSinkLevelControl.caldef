      <Entry>
        <Key>6</Key>
        <Value>0.0</Value>
      </Entry>
      <Entry>
        <Key>7</Key>
        <Value>0.0</Value>
      </Entry>
      <Entry>
        <Key>8</Key>
        <Value>0.0</Value>
      </Entry>
      <Entry>
        <Key>9</Key>
        <Value>0.0</Value>
