  <CalDefinition Description="This calibration is used to Enable/Disable the display of this Application on the HomeScreen and in the App Tray. Note: The first/overriding condition for determining if this HomeScreen Application shall be displayed on the HomeScreen is the value of NAV feature calibration (ENABLE_APPLICATION_NAVIGATION). When the value of the ENABLE_APPLICATION_NAVIGATION is set to False (Disabled), this HomeScreen Application shall not be displayed on the HomeScreen no matter what the value of this calibration (APPLICATION_HOMESCREEN_NAV_ENABLED) is set to. When the ENABLE_APPLICATION_NAVIGATION is set to True, the value of the APPLICATION_HOMESCREEN_NAV_ENABLED calibration is then used as the next/secondary condition for determining if this HomeScreeHomeScreen Appliation shall be displayed on the HomeScreen. When this calibration (APPLICATION_HOMESCREEN_NAV_ENABLED) is set to True (Enabled), this HomeScreen Application shall be displayed on the HomeScreen. When this calibration is set to False (Disabled), this HomeScreen Application shall not be displayed on the HomeScreen." Name="APPLICATION_HOMESCREEN_NAV_ENABLED" References="GIS-501" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_VGwAgDw7EeaGEeA8k3J6-w</CalID>
    <Type>Boolean</Type>
    <Version>4</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>6/24/2016</Date>
      <Description>Initial release of this calibration</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/13/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/1/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>9/28/2020</Date>
      <Description>Default changed to False per CR 2526202</Description>
      <Author>Greg Lindemann</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="This calibration is used to Enable/Disable the display of this Application on the HomeScreen and in the App Tray. When this calibration is set to True (Enabled), this HomeScreen Application shall be displayed on the HomeScreen. When this calibration is set to False (Disabled), this HomeScreen Application shall not be displayed on the HomeScreen. " Name="APPLICATION_HOMESCREEN_NAVLVM_ENABLED" References="GIS-501" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
