  <CalDefinition Description="A PromptRendering_Enable calibration shall be provided to serve as a master enable/disable &quot;switch&quot; to allow the feature to be enabled or disabled without requiring a software change.   If the feature is turned by setting the PromptRendering_Enable calibration to FALSE, then the HMI display shall not show any UI controls or status information associated with Prompt Rendering.  The allows the Prompt Rendering feature to be added/removed using a calibration." Name="DirectionalAudioPromptRendering_Enable" References="" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_TN76UD_tEeeK3tJi-kcCzA</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingRange_Enum calibration is used within the HMI controller to define the range bracket enumerations required to support the Directional Audio Prompt Rendering function." Name="DirectionalAudioPromptRenderingRange_Enum" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_aJmYgD8gEeiX3IvJZ57jLQ</CalID>
    <Type>Enumeration</Type>
    <Version>1</Version>
    <Enumeration>
      <EnumID>_zRUsYD_vEeeK3tJi-kcCzA</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingDirection_Enum calibration is used within the HMI controller to define the Navigation TTS direction enumerations required to support the Directional Audio Prompt Rendering function." Name="DirectionalAudioPromptRenderingDirection_Enum" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_q221cD8fEeiX3IvJZ57jLQ</CalID>
    <Type>Enumeration</Type>
    <Version>1</Version>
    <Enumeration>
      <EnumID>_bdTBED_wEeeK3tJi-kcCzA</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingZone_Enum calibration is used within the HMI controller to define the audio Zone enumerations required to support the Directional Audio Prompt Rendering function.  Distance Bracket = Set to map reported range bracket to a set of audio zones defined by General Motors for this application.  " Name="DirectionalAudioPromptRenderingZoneEnum" References="" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_ChuFUD59EeiBsqlGvScL3g</CalID>
    <Type>Enumeration</Type>
    <Version>1</Version>
    <Enumeration>
      <EnumID>_pNxHUD_wEeeK3tJi-kcCzA</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingDistanceMap is an array calibration used within the HMI controller to map the reported &lt;distance> attribute from navigation for a given TTS prompt to provide a distance based range bracket using the enumerations defined in the Configuration section above. " Name="DirectionalAudioPromptRenderingDistanceMap" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_J_LnUD57EeiBsqlGvScL3g</CalID>
    <Type>IntegerArray</Type>
    <Version>1</Version>
    <IntegerArray>
      <ArrayLength>7</ArrayLength>
      <MinValue>0</MinValue>
      <MaxValue>2000</MaxValue>
      <Resolution>1.0</Resolution>
      <ArrayValue>150</ArrayValue>
      <ArrayValue>300</ArrayValue>
      <ArrayValue>1600</ArrayValue>
      <ArrayValue>1600</ArrayValue>
      <ArrayValue>0</ArrayValue>
      <ArrayValue>0</ArrayValue>
      <ArrayValue>0</ArrayValue>
    </IntegerArray>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingZoneMap calibration is defined as an array to map the range brackets and direction to a defined zone. For example,  0, 1, 1 defined in the cal definiton below means: &quot;Range Bracket 0, Direction Left, Zone 6&quot;. If the value of zero is selected for this calibration, the CSM shall NOT render this prompt directionally (standard prompt, non-directional)." Name="DirectionalAudioPromptRenderingZoneMap" References="" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_vXyQ4D9JEeijcMex7f4qKw</CalID>
