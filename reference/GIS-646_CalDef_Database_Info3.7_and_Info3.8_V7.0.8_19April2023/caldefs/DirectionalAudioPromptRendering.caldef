  <CalDefinition Description="An HMI calibration defined as Prompt_Rendering_Enable_Menu_Item_On shall be used to set the default (i.e., factory built initial state) for the Prompt Rendering feature in the UI. The default state is ON == Prompt Rendering ENABLED. This allows the feature to be enabled when a User takes delivery of the vehicle." Name="DirectionalAudioPromptRenderingMenuItem_On" References="" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_ZInogD_LEee4MeDnqjMD-Q</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
