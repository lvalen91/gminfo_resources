<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef">
  <CalDefFileVersion>2</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>4/16/2018</Date>
    <Description>CR1344108: Added DirectionalAudioPromptRenderingRange_Enum, DirectionalAudioPromptRenderingDirection_Enum, DirectionalAudioPromptRenderingZone_Enum, DirectionalAudioPromptRenderingDistanceMap, DirectionalAudioPromptRenderingZoneMap_Decision, DirectionalAudioPromptRenderingRangeMap_Range_Bracket_0 to Range_Bracket_3, DirectionalAudioPromptRenderingRangeMap_Custom_1 to Custom_3; update DirectionalAudioPromptRendering_Enable name to match specs</Description>
    <Author>Kiran Soni</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="A DirectionalAudioPromptRenderingRangeMap is an array calibration used within the HMI controller to map the range brackets to a defined zone used for processing Navigation TTS commands which include Center or None as &lt;direction> attributes (i.e., not a &quot;right&quot; or &quot;left&quot; turn direction).  These zones are identified as Zone 11, 12, and 13.  Up to six range brackets can be identified to allow customization for range settings. Distance Bracket = Set to map reported range bracket to a set of audio zones defined by General Motors for this application. " Name="DirectionalAudioPromptRenderingRangeMap_Custom_3" References="" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_XXyN0T9EEei2tsrzDiA2EQ</CalID>
    <Type>Enumeration</Type>
    <Version>1</Version>
    <Enumeration>
      <EnumID>_pNxHUD_wEeeK3tJi-kcCzA</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="A DirectionalAudioPromptRenderingRangeMap is an array calibration used within the HMI controller to map the range brackets to a defined zone used for processing Navigation TTS commands which include Center or None as &lt;direction> attributes (i.e., not a &quot;right&quot; or &quot;left&quot; turn direction).  These zones are identified as Zone 11, 12, and 13.  Up to six range brackets can be identified to allow customization for range settings. Distance Bracket = Set to map reported range bracket to a set of audio zones defined by General Motors for this application. " Name="DirectionalAudioPromptRenderingRangeMap_Custom_2" References="" Usage="MID,HIGH,GLOBALB,VCU">
