<?xml version="1.0" encoding="ASCII"?>
<ns1:CalDefinitionFile xmlns:ns1="http://www.caltools.gm.com/caldef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Description="Intended to include Global B specific calibrations for the GIS-619">
  <CalDefFileVersion>5</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>5/24/2016</Date>
    <Description>Initial release of this caldef file to include Global B specific calibrations for the GIS-619.</Description>
    <Author>Younus Syed</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>6/15/2017</Date>
    <Description>Updated the usage field for all of the calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>10/2/2017</Date>
    <Description>Within the GIS619_BrightnessControl_GlobalB.caldef  file, added GEM usage to all of the calibrations within this caldef except for the two calibrations {  (1.) OPTICAL_DRIVE_BRIGHTNESS_INPUT_TABLE_GLOBALB and (2.)OPTICAL_DRIVE_BRIGHTNESS_OUTPUT_TABLE_GLOBALB }. Note, did not add GEM usage for these two calibrations since both of these calibraions did not fall within the current criteria of requiring GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>09/14/2018</Date>
    <Description>Per CR#1879935, Updated GIS619_Brightness_Control_GlobalB.caldef changed default value for LOCAL_MODE_DIMMING_LEVEL_GLOBALB calibration.</Description>
    <Author>Younus A. Syed</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="Local Mode Dimming Level is the level used for dimming computations in the UserInitiated LocalInfotainment and LocalValet states as defined in GIS-618.  Default value is N-value, where E=(N)*1.0  and E is dimming level in percent luminance." Name="LOCAL_MODE_DIMMING_LEVEL_GLOBALB" References="GIS-619-150 " Usage="LOW,MID,HIGH,GEM,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_1MpY4Ay6Eeab4ezHobftRw</CalID>
    <Type>Integer</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Date>
      <Description>10/2/2017</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>09/14/2018</Date>
      <Description>Updated default value from 25 to 40. </Description>
      <Author>Younes A. Syed</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>40</Value>
      <MinValue>0</MinValue>
      <MaxValue>127</MaxValue>
      <Units>percent</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Main Display Brightness Failsoft Output.  Default value is N-value, where E=(N/65535)*100 and E is dimming level in percent luminance.  " Name="DISPLAY_BRIGHTNESS_FAILSOFT_GLOBALB" References="GIS-619-150 " Usage="LOW,MID,HIGH,GEM,GLOBALB,ENTRY_VCU,VCU">
