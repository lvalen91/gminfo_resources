    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>09/18/2018</Date>
      <Description>Initial release of this calibration</Description>
      <Author>Ibnul Khan</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>22</Value>
      <MinValue>16</MinValue>
      <MaxValue>30</MaxValue>
      <Units>degrees</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration determines the Temperature value (in Fahrenheit) where the color transition from Blue to Red and vice versa (MFC Mode)" Name="RearClimateTempColorFahrenheit" References="GIS1050 Section5.1" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_K0ZHMLoxEeiSab6pnJ7Ihg</CalID>
