    </CalDefChangeRecord>
    <Integer>
      <Value>61</Value>
      <MinValue>50</MinValue>
      <MaxValue>100</MaxValue>
      <Units>degrees</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration determines the Temperature value (in Celsius) where the color transition from Blue to Red and vice versa (MFC Mode)" Name="RearClimateTempColorCelsius" References="GIS1050 Section5.1" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_l7J5ILoxEeiSab6pnJ7Ihg</CalID>
