    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>09/18/2018</Date>
      <Description>Initial release of this calibration</Description>
      <Author>Ibnul Khan</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>17</Value>
      <MinValue>16</MinValue>
      <MaxValue>30</MaxValue>
      <Units>degrees</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Rear climate minimum temperature value before HMI displays &quot;LO&quot; as the temperature value." Name="RearClimateMinTempFahrenheit" References="GIS1050 Section5.1" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_W49P0LoyEeiSab6pnJ7Ihg</CalID>
