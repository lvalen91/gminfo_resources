  <CalDefinition Description="Mini Mode also allows for both the driver and the passenger to be&#xA;adjusting their seats simultaneously.&#xA;The Driver always gets priority in controlling their seat. If the Passenger&#xA;is controlling their seat and the driver begins to play with&#xA;their seat control  the Driver seat would shift to the 3/4 view and&#xA;the passenger would go to mini mode.&#xA;Figure 9.18.8.1 shows the passenger with primary control. If the&#xA;Driver operates the switch  the view would switch to give the&#xA;Driver screen dominance as shown in Figure 9.18.8.2&#xA;If the Driver completes their interaction  after 3 seconds (calibratable)&#xA;when their pane times out  the Passenger would regain the&#xA;dominant view." Name="MWS_PANE_PASSENGER_VIEW_DELAY" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_yrTQa01AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_country_caln</Description>
      <Author>GIS-344 GIS-343</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>4/17/2015</Date>
      <Description>Per request from Sanghyun Ryu updated MWS_PANE_PASSENGER_VIEW_DELAY cal to remove usage of Low Radio.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>3000</Value>
      <MinValue>0</MinValue>
      <MaxValue>25500</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="MULTIWAYSEAT_STATUS_PANE_AUTO_DISMISS_TIMER - calibration to set the time period to wait before auto-dismissing  the Seat Status Pane  due to inactivity with the seat switch controls.  Type - ENM  Range = 0-255 Sec  Resolution = 1 Sec  Default = 3 Sec.&#xA;" Name="MWS_PANE_AUTO_DISMISS_TIMER" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_yrTQbE1AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_country_caln</Description>
      <Author>GIS-344 GIS-343</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>4/17/2015</Date>
      <Description>Per request from Sanghyun Ryu updated MWS_PANE_AUTO_DISMISS_TIMER cal to remove usage of Low Radio.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>3</Value>
      <MinValue>0</MinValue>
      <MaxValue>255</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="MULTIWAYSEAT_STATUS_PANE_MINI_MODE_TIMER - calibration to set the time period to wait before switching the dominant view (i.e.  Driver OR Passenger) in the Miniature Seat Status Pane (Mini Mode).  Type - ENM  Range = 0-255 Sec  Resolution = 1 Sec  Default = 3 Sec." Name="MWS_PANE_MINI_MODE_TIMER" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_yrTQbU1AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_country_caln</Description>
      <Author>GIS-344 GIS-343</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>4/17/2015</Date>
      <Description>Per request from Sanghyun Ryu updated MWS_PANE_MINI_MODE_TIMER cal to remove usage of Low Radio.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>3</Value>
      <MinValue>0</MinValue>
      <MaxValue>255</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="MULTIWAYSEAT_STATUS_PANE_SUPPRESSION_TIMER - calibration to set the time period to wait after the Seat Status Pane is suppressed into mini mode  before returning back to full screen mode.  Type - ENM  Range = 0-255 Sec  Resolution = 1 Sec  Default = 20 Sec." Name="MWS_PANE_SUPPRESSION_TIMER" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_yrTQbk1AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_country_caln</Description>
      <Author>GIS-344 GIS-343</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>4/17/2015</Date>
      <Description>Per request from Sanghyun Ryu updated MWS_PANE_SUPPRESSION_TIMER cal to remove usage of Low Radio.</Description>
      <Author>Ginanrd Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>20</Value>
      <MinValue>0</MinValue>
      <MaxValue>255</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
</caldef:CalDefinitionFile>