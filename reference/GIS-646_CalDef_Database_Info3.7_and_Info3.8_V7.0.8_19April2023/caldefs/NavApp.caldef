  <CalDefinition Description="The AR System utilizes the K_DESTINATION_HIGHLIGHT_ENABLE calibratable Configuration parameter to disable or enable the AR &quot;Destination Highlilghting&quot; functionality.  This feature can be turned off by this calibration if it is not functional at the time of vehicle production.  This feature can also be turned off for non-Info3.5C vehicles that do not support Augmented Reality.  [ New MY21 AR ]" Name="K_DESTINATION_HIGHLIGHT_ENABLE" References="GIS-620 Navigation Functional Requirements, GIS-1064 Augmented Reality UI Specification - Form and Behavior" Usage="MID,HIGH,VCU,GLOBALB">
    <CalID>_ITvs4DnHEeefbJ5EEtYQTQ</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>4/11/2018</Date>
      <Description>CR 992975 MFL D20-65_21MY: Augmented Reality AR - Navigation Destination highlight - for Info 3.5C only, initial release of K_DESTINATION_HIGHLIGHT_ENABLE for GIS-620</Description>
      <Author>Paul Wagner</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
