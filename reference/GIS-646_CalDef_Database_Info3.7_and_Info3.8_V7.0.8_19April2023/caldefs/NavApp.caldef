      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>8/13/2015</Date>
      <Description>Updated the CAL default value used for the ECO_ROUTE_CURVE CAL due to the update within the NavApp.enumdef file to make the enumeration names more generic for this CAL.</Description>
