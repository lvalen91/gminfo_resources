      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/1/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Enumeration>
      <EnumID>_eCTBYG7dEeSssq_awwoZ3g</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="As the user is entering digits, the number is auto completed based upon matches to the recent call history. If there are multiple matches, the match shown is based upon the most recent date. The digits entered by the user will be shown visually different from the auto entry numbers. The user continues entering digits if the autocomplete phone number is not the desired phone number. The autocomplete is available when the user is not in a call or is in the add call mode." Name="EnablePhoneAutoComplete" References="GIS-503 5.1.1.1*MY17 Calibration Items" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_-fHSAG7dEeSssq_awwoZ3g</CalID>
    <Type>Boolean</Type>
