<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" CalDefCategory="Chime">
  <CalDefFileVersion>7</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>5/31/2016</Date>
    <Description>Restructuring of caldef file based on development CRs for Global B Chime Producer requirements.  New CalIDs assigned for each chime event as well as reforming of sound tone cal IDs.  Work done as part of MY19 Global B CR 19.19.120.761808.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>10/21/2016</Date>
    <Description>MY19 Info 3 CR:  1218149 -- Removed Chime Event 174 triggered due to vehicle CR 829313.  Added Events 935, 936, 615, 937, 938, 617 due to vehicle CR 822377.  Removed events 105, 110, 115, 120 and added event 585 due to vehicle CR 1083521.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>12/7/2016</Date>
    <Description>Updated Cal Def file to include new chime event 110 to support Passive Safety CR 1237029 with the Type 2 Global B SBR Chime for meeting EU Regulation.  Category value for all Chime Events correctly set to 12 instread of 15 to align correctly with GIS-631.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>2/15/2017</Date>
    <Description>Updated Cal Def file to include new chime event 586 to support Active Safety CR 1239990.  Updated default values of Chime Events 575 and 580 as part of Active Safety CR 1239990.  </Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>23MAY2017</Date>
    <Description>Updated &quot;Usage&quot; field to support new &quot;Global A/Global B&quot; categorization.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="String up to 255 characters providing versioning information about the theme." Name="K_THEME_1_VERSION" Usage="LOW,MID,HIGH,ENTRY_VCU,VCU">
    <CalID>_TSNasErcEeOF3P4e5N5VOg</CalID>
    <Type>String</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>11JAN2016</Date>
      <Description>Initial release</Description>
      <Author>Dominic Colella</Author>
    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>255</MaxLength>
      <StringValue>20.20.133</StringValue>
    </String>
  </CalDefinition>
  <CalDefinition Description="A Calibration that specifies the overall amplitude offset to apply when playing any chime event from the prescribed theme.  " Name="K_THEME_1_LEVEL_OFFSET" Usage="LOW,MID,HIGH,ENTRY_VCU,VCU">
    <CalID>_a3AB0ErcEeOF3P4e5N5VOg</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>11JAN2016</Date>
      <Description>Initial release</Description>
      <Author>Dominic Colella</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>23MAY2017</Date>
      <Description>Updated range of calibration as based off tuning lessons learned.  </Description>
      <Author>Dominic Colella</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>0</Value>
      <MinValue>-20</MinValue>
      <MaxValue>20</MaxValue>
      <Units>dB</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
