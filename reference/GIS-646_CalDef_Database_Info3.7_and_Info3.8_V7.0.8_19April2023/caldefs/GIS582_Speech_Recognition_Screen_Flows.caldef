  <CalDefinition Description="Time prior to the end of TTS prompt playback that the Early Speak BargeIn listening window opens." Name="SR_EARLY_SPEAK_TIME" References="GIS 582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
