    </CalDefChangeRecord>
    <Integer>
      <Value>24000</Value>
      <MinValue>100</MinValue>
      <MaxValue>30000</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The album type first threshold (T1) represents the amount of songs above which direct access by speech to that type of content is not allowed at the top level of the interface, but access to the content is still allowed if the user first speaks a command which indicates the type of content they desire, then they will be asked to identify the album explicitly. " Name="Album_Slot_T1_Threshold" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_J54BoH88EeWMmJGlhCyCXg</CalID>
