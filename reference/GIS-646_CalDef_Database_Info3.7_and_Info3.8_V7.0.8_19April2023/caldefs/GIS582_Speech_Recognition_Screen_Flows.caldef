  <CalDefinition Description="The media type first threshold (T1) represents the amount of songs above which direct access by speech to that type of content is not allowed at the top level of the interface, but access to the content is still allowed if the user first speaks a command which indicates the type of content they desire, then they will be asked to identify the song or album explicitly. " Name="Genre_Artist_Playlist_Slot_T1Threshold" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_ygLh4H88EeWMmJGlhCyCXg</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/30/2015</Date>
      <Description>Initial release of this CAL</Description>
      <Author>Xufang Zhao</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>12000</Value>
      <MinValue>100</MinValue>
      <MaxValue>30000</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The second threshold (T2) represents the amount of albums above which direct access by speech to that type of content is not allowed at any level of the interface." Name="Album_Slot_T2_Threshold" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_exFhEH88EeWMmJGlhCyCXg</CalID>
