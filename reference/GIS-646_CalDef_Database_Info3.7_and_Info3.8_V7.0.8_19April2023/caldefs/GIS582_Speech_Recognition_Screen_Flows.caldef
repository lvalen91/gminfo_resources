      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The second threshold (T2) represents the amount of songs above which direct access by speech to that type of content is not allowed at any level of the interface." Name="SongType_Slot_T2_Threshold" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_nZyRsH87EeWMmJGlhCyCXg</CalID>
