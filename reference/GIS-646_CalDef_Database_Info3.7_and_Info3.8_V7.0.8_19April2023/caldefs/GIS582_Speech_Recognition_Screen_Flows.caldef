    <Integer>
      <Value>200</Value>
      <MinValue>100</MinValue>
      <MaxValue>600</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Maximum time that systems will wait for ASR results before playing the prompt of &quot;please wait&quot; to users" Name="PLEASE_WAIT_ACTIVE_TIMER" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_L8iVMIPXEeWMQP73BwB68g</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
