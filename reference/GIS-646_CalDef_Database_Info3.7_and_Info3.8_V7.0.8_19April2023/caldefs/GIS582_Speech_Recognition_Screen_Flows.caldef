    </CalDefChangeRecord>
    <Integer>
      <Value>2000</Value>
      <MinValue>1000</MinValue>
      <MaxValue>5000</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The recognition feedback prompt will not be played before a minimum inter-prompt delay expires after the processing prompt. The current speech screen will display the &#x2018;processing&#x2019; graphic from the end of user speech until the system recognition response to reinforce the fact that the system is processing the user input." Name="SR_Min_Inter_Prompt_Time" References="GIS-582" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_Pue80IPXEeWMQP73BwB68g</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>3/3/2016</Date>
      <Description>Adding this new calibration for MY18 for SSE tuning thresholds.</Description>
      <Author>Xufang Zhao</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>1500</Value>
      <MinValue>1000</MinValue>
      <MaxValue>5000</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
