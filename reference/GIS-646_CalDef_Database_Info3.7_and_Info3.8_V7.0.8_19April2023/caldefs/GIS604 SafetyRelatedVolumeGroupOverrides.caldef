  <CalDefinition Description="Each function will be supported by a calibration parameter to enable the override." Name="TJA_TRANSITION_DEMAND_VOL_OVRD_ENABLE" References="GIS-604-824" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
