  <CalDefinition Description="A calibration parameter to hold the volume group override level at for a duration after the activation criteria have ceased." Name="SAFETY_VOL_OVRD_DWELL" References="GIS-604-824" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_5ANYsPO6EeavdZd7UaL_VA</CalID>
    <Type>Integer</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
