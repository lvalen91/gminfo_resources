    </Boolean>
  </CalDefinition>
  <CalDefinition Description="LOST COMMUNICATION WITH INSTRUMENT PANEL CLUSTER.  Upon notification by the handler that the associated supervised signal has failed supervision (typically 2.5 times the nominal periodic rate of the monitored signal). An adjustable debounce time, i.e. X of Y strategy, is permitted at the time that notification of failed supervision has been received by the application to delay storing of the DTC." Name="DTC_MASK_U0155_00" References="GIS-641, GIS-657" Usage="MID,HIGH,GLOBALB">
    <CalID>_vy7BYBzwEeaksf3dHPIIEA</CalID>
    <Type>Boolean</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>05/20/16</Date>
      <Description>Official release of diagnostic trouble code</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/13/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>9/17/2021</Date>
      <Description>Added back in&#xa0;the DTC_MASK_U0155_00 calibration that was removed in the Info3.7/3.8 Cal DB v7.0.5 release. The GM Sustain team confirmed this calibration is still needed for Info3.7 to support DTCs U0155_00 that is still in the GB_ODX_22.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
