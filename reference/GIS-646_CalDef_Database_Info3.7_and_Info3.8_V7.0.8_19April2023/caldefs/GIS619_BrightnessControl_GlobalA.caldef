<?xml version="1.0" encoding="ASCII"?>
<ns1:CalDefinitionFile xmlns:ns1="http://www.caltools.gm.com/caldef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Description="Intended to include Global A specific calibrations for the GIS-619">
  <CalDefFileVersion>8</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>29SEP14</Date>
    <Description>Add Usage on all components</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>06FEB15</Date>
    <Description>Changed INDICATOR_BRIGHTNESS_SOURCE default value to DEADFRONT.</Description>
    <Author>John Edens</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>4/17/2015</Date>
    <Description>Per request from Sanghyun Ryu updated OPTICAL_DRIVE_BRIGHTNESS_INPUT_TABLE and OPTICAL_DRIVE_BRIGHTNESS_OUTPUT_TABLE cals in this caldef file to remove usage of Low Radio.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>7/1/2016</Date>
    <Description>Changed the name of the GIS619_BrightnessControl.caldef file to GIS619_BrightnessControl_GlobalA.caldef that contains the Global A specific calibrations for the GIS-619 to distinquish it from the GIS-619 Global B caldef file being added in this release that contains the Global B specific calibrations for the GIS-619. </Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>6/15/2017</Date>
    <Description>Updated the usage field for all of the calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>8</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="Local Mode Dimming Level is the level used for dimming computations in the UserInitiated LocalInfotainment and LocalValet states as defined in GIS-618.  Default value is N-value, where E=(N/255)*100  and E is dimming level in percent luminance." Name="LOCAL_MODE_DIMMING_LEVEL" References="GIS-619-150 " Usage="LOW,MID,HIGH,GLOBALA,ENTRY_VCU,VCU">
