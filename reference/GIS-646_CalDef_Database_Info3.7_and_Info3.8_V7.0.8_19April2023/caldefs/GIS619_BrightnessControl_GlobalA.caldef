    </Integer>
  </CalDefinition>
  <CalDefinition Description="Lag filter low end threshold.  When FilteredValue &lt;= this threshold, the output of the FilteredValue shall be set to zero.  Default value is N-value, where E=(N/65535)*100 is the low end threshold." Name="LAG_FILTER_LOW_END_THRESHOLD" References="GIS-619-150 " Usage="LOW,MID,HIGH,GLOBALA,ENTRY_VCU,VCU">
