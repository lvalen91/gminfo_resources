    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>32</MaxLength>
      <StringValue></StringValue>
    </String>
  </CalDefinition>
  <CalDefinition Description=" WiFiNumSupportedDevices is the maximum number of Wi-Fi devices that can be supported by the Wi-Fi Module (for consumer devices in P2P mode and STA mode)" Name="WiFiNumSupportedDevices" References="GIS-331 4111,5214" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
