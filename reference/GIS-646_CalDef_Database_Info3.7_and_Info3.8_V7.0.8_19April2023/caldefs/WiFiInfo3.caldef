  <CalDefinition Description="NumWiFiDevicesFiltered describes the maximum number of consumer devices (in STA mode) that can be allowed to connect to the WiFi Module" Name="NumWiFiDevicesFiltered" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
