    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>2/19/2015</Date>
      <Description>This cal is being added to associate to the enum that already existed in the BluetoothFeaturesEnable.enum. This CAL replaced ENABLE_MICROPHONE_1 that was incorrectly being shown as a Boolean type Cal.</Description>
      <Author>Bassam Shahmurad</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>9/29/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Enumeration>
      <EnumID>_yrQ0LE1AEeO3UM5MzM17kw</EnumID>
      <Value>1</Value>
    </Enumeration>
  </CalDefinition>
