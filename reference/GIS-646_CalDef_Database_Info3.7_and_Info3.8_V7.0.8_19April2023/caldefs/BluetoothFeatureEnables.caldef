      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="This cal guards the automatic ODI calls from the AVManager to the remote ECC on LSGMLAN via FUClass-7 HVACSettings FanSpeedReduction Action #50.  See GIS-302-2997 for detailed triggering requirements." Name="K_AUTO_FAN_SPEED_REDUCTION_ENABLED" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
