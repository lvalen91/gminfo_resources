  <CalDefinition Description="Map of AudioStreamEnum audio streams for each audio source to the corresponding source offset in dB." Name="SourceOffsetCalibrationMap" References="GIS-604-320" Usage="LOW,ENTRY_VCU,GEM,GLOBALA,GLOBALB,MID,HIGH,VCU">
    <CalID>_ATpg4CR6EeOFAcqdxEN3jw</CalID>
    <Type>EnumFloatMap</Type>
    <Version>6</Version>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/31/2014</Date>
      <Description>Addition of &quot;STREAM_NATIVE_HFM_WB&quot; to SourceOffsetCCalibrationMap calID file.  This is in response to Harman Assembla ticket #1223.</Description>
      <Author>Dominic Colella</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>6/24/2016</Date>
      <Description>Made the following default value updates based on feedback from MY17 vehicle testing: STREAM_MUSIC - Default value changed from 0 to 3 dB, 14.STREAM_NATIVE_AM_TUNER - Default value changed from 0 to 3 dB, STREAM_NATIVE_SDARS_TUNER - Default value changed from 0 to 7 dB, STREAM_NATIVE_IPOD - Default value changed from 0 to 5 dB, STREAM_NATIVE_DTCP_CALL - Default value changed from 5 to 16 dB, STREAM_VOICE_CALL - Default value changed from 0 to 24 dB, STREAM_NATIVE_MEDIA_PLAYER - Default value changed from 0 to 4 dB, STREAM_NATIVE_BLUETOOTH_AUDIO - Default value changed from 0 to 4 dB, and STREAM_NATIVE_LVM_STEREO_AUDIO  - Default value changed from 0 to 20 dB.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>5</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>6</Version>
      <Date>10/2/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
