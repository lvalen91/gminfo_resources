  <CalDefinition Description="B395A_08 &#x2013; Invalid/Incorrect/loss of Low Voltage Differential Signal Sync Pulse " Name="DTC_MASK_B395A_08" References="GIS-621 Section 22.3.17" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_6SSVUEFlEeaX676o0O3GfQ</CalID>
