  <CalDefinition Description="B101D_3B_ELECTRONIC CONTROL UNIT HARDWARE.  ECU Hardware Performance internal self-test failed - This sub type is used by the ECU to indicate a sensor self-test failure launched by an ECU command." Name="DTC_MASK_B101D_3B" References="GIS-621 Section 22.2.1" Usage="MID,HIGH,GLOBALA">
