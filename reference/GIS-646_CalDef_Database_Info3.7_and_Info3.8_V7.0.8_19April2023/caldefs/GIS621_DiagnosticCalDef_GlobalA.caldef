      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="Debounce Time shall be 2.5 Times the Timeout (timeout is 2.5 times the nominal periodic rate of the signal." Name="DEBOUNCE_TIME" References="GIS-621 1.12.1" Usage="MID,HIGH,GLOBALA">
    <CalID>_zPjjcBObEeWRRp_APrKM0Q</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>6/15/2015</Date>
      <Description>Deleted the DEBOUNCE_TIME CAL that was incorrected defined as a Boolean type CAL in the previous version of this caldef file, and replacing with this new DEBOUNCE_TIME CALCAL correctly defined as an Integer.</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>2/26/2016</Date>
      <Description>Changed the units from seconds to milliseconds, and updated the maximum and default values defined for the DEBOUNCE_TIME CAL.</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>2500</Value>
      <MinValue>0</MinValue>
      <MaxValue>10000</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="DTC Enable Criteria.  It is important that the test enable criteria exclude power modes where the CSM MODULE is not supposed to be fully functional.  If a DTC is enabled in Crank Request this has to be motivated and clearly shown that no false (ghost) codes will be set. For DTC&#x2019;s enabled in Off and Accessory power mode, they shall be linked with a secondary parameter (i.e. system voltage range) that clearly inhibit setting false (ghost) codes in under-voltage conditions" Name="DTC_CRANK_DELAY_TIME" References="GIS-621 -> 13.11" Usage="MID,HIGH,GLOBALA">
    <CalID>_iBYC0JPjEeObkJNbevKUAw</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>5/16/16</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>5</Value>
      <MinValue>0</MinValue>
      <MaxValue>255</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="DTC_ENABLE_CRITERIA -Each fault detection algorithm may only be active (test running) in specific vehicle power modes or when a specific Virtual Network is active. All power modes/VN active states where the fault detection algorithm is active shall be specified for each DTC." Name="VN_ACTIVATION" References="GIS-621 1.12.1" Usage="MID,HIGH,GLOBALA">
    <CalID>_Btq70JjOEeOY6q-k73fxZA</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>5/13/16</Date>
      <Description>Virtual Network Activation</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="DTC_ENABLE_CRITERIA - All DTC's should not set within 5 seconds of a under or over voltage condition." Name="RECOVERY_UNDER_OVER_VOLTAGE" References="GIS-621 1.12.1" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_Cww7EJjPEeOY6q-k73fxZA</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/24/14</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>9</Value>
      <MinValue>9</MinValue>
      <MaxValue>16</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="There shall be an automatic clearing of DTC Information method implemented within the CSM MODULE.  All DTC Status and Failure Type information shall be cleared within the CSM Module when the Fault Free Ignition Cycle Counter reaches [calibration: DTC_IGN_CYCLE_CTR_MAX].  There shall be a single Fault Free Ignition Cycle Counter in the ECU which tracks the automatic clearing of DTC Information for all DTCs supported within the CSM MODULE (i.e., the report of a test fail result for any DTC supported by the ECU will reset the Fault Free Ignition Cycle Counter.)" Name="DTC_IGN_CYCLE_CTR_MAX" References="GIS-621 4.1.5" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_sCm2wJwJEeSUfZTikgbI3Q</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>2/16/15</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>5/13/2016</Date>
      <Description>Added the description shown in GIS-621 for DTC_IGN_CYCLE_CTR_MAX since a description was not shown previously for it in the CAL Database.</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>0</Value>
      <MinValue>0</MinValue>
      <MaxValue>40</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="DID $2F &#x2013; VEHICLEIDENTIFICATIONNUMBER DIGITS 2-17. This DID contains the Vehicle Identification Number.  The data content shall be specified by the vehicle manufacturer.  If the VIN has not yet been programmed into the ECU's permanent memory, those locations shall be either '$00' or '$FF'." Name="DID_MASK_2F" References="GIS-621 4.1.7" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_In5RoJwJEeSUfZTikgbI3Q</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>1/15/15</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="DID_B6_BYTE_1_MODEL_YEAR - This byte is an USN value that represents the target model year using the year 1900 as the base year. To represent the 2000 model year, the value of byte 1 would be 100 or ($64). This is derived from 1900 + 100 = 2000. If the module supports multiple model years, then this byte is filled in with $23 (ASCII equivalent to &#x201c;#&#x201d;)." Name="DID_B6_BYTE_1" References="GMW 3110 Appendice C" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_6dugwLXAEeOAHtc5B2bVlA</CalID>
    <Type>Integer</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/14/14</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>0</Value>
      <MinValue>-2147483648</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="DID_B6_BYTE_2_VEHICLE_MAKE - This byte is the ASCII representation of the Vehicle Make as Identified in the Vehicle Identification Number (VIN). For example, Cadillac = 6 or $36. If the part is used in multiple vehicle makes, then a value of $23 (ASCII &#x201c;#&#x201d;) is used. " Name="DID_B6_BYTE_2" References="GMW 3110 Appendice C" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_CP1LILXBEeOAHtc5B2bVlA</CalID>
    <Type>String</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/14/14</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>100</MaxLength>
      <StringValue>TODO</StringValue>
    </String>
  </CalDefinition>
  <CalDefinition Description="DID_B6_BYTE_3_VEHICLE_CAR_LINE - This byte is an ASCII character representing the vehicle car line (e.g., J for Chevy Cavalier). If the module can be used in multiple car lines, then a value of $23 (ASCII &#xfffd;&#xfffd;&#xfffd;#&#xfffd;&#xfffd;&#xfffd;) is used." Name="DID_B6_BYTE_3" References="GMW 3110 Appendice C" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_LW1y8LXBEeOAHtc5B2bVlA</CalID>
    <Type>String</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/14/14</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>100</MaxLength>
      <StringValue>TODO</StringValue>
    </String>
  </CalDefinition>
  <CalDefinition Description="DID_B6_BYTE_4_5_ENGINE_RPO - Bytes 4 and 5 contain the ASCII representation of the last two characters of the engine Regular Production Option (RPO). The first character of an engine RPO is constant and is therefore not stored. For the L67 engine, the value for these two bytes would be &#x201c;6&#x201d; = $36, and &#x201c;7&#x201d; = $37. If the module is to be used with multiple engines, then a $23 (ASCII &#x201c;#&#x201d;) is put in both bytes. If the module can be used with any engine type, then $2A (ASCII &#x201c;*&#x201d;) is put in both bytes. " Name="DID_B6_BYTE_4_5" References="GMW 3110 Appendice C" Usage="MID,HIGH,GLOBALA,VCU">
    <CalID>_TCl9sLXBEeOAHtc5B2bVlA</CalID>
    <Type>String</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>10/14/14</Date>
      <Description>Initial Release</Description>
      <Author>David Bonello</Author>
    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>100</MaxLength>
      <StringValue>TODO</StringValue>
    </String>
  </CalDefinition>
