      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>10</Value>
      <MinValue>0</MinValue>
      <MaxValue>1275</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>5.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="In order to allow flexibility when using the mute/unmute function, three(3) calibratible ramp parameters are usable by the Audio Manager when commanding the Amplifier to mute or unmute the Mutex Sink.  The ramp parameters are calibrations provided in the Audio Manager as numeric values between 0 and 1275 ms with a resolution of 5 ms.  The calibrations shall be implemented within either the CSM or Low Radio depending on system configuration.  The usage of the ramp rates shall be configurable according to which sources are former and current to produce desirable transitions in audio sources. " Name="K_MUTEX_SINK_RAMP_1" References="GIS-604-655" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
