      <Value>0</Value>
      <MinValue>-2147483648</MinValue>
      <MaxValue>2147483647</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="If View360_DisplayAboveSpeed calibration is false (Off) and the vehicle is travelling at a speed greater than View360_AboveSpeedValue calibration value, the 360 View is not displayed." Name="View360_DisplayAboveSpeed" References="GIS1016 Section 5.1" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_2fZq0LwvEei0V4exoe3Bew</CalID>
