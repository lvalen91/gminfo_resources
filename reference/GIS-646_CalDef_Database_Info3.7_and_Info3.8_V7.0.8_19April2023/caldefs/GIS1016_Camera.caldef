  <CalDefinition Description="If View360_DisplayAboveSpeed calibration is false (Off) and the vehicle is travelling at a speed greaterthan this calibration value, the 360 View is not displayed." Name="View360_AboveSpeedValue" References="GIS1016 Section5.1" Usage="MID,HIGH,GLOBALB,VCU">
