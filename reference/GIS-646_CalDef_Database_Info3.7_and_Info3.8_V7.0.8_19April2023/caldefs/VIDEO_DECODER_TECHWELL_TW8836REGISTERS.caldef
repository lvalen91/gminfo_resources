    </CalDefChangeRecord>
    <Integer>
      <Value>1</Value>
      <MinValue>0</MinValue>
      <MaxValue>3</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="VERTICAL PEAKING CONTROL I ; Note as defined in the TW8836 data sheet: FUNCTION: VSHP; DESCRIPTION: Vertical peaking gain control" Name="REGISTER_0x117_BITS_2_thru_0" References="TECHWELL TW8836 Data Sheet" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
    <CalID>_JR1T8CxrEeW8XK_nvVgh2w</CalID>
