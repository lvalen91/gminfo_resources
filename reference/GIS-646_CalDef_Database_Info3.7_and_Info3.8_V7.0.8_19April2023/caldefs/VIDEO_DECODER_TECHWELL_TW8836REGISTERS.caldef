      <MaxValue>7</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="SHARPNESS CONTROL REGISTER I (SHARPNESS); Note as defined in the TW8836 data sheet: FUNCTION: SCURVE; DESCRIPTION: This bit controls the center frequency of the peaking filter. The corresponding gain adjustment is HFLT. Also, 0 = low and 1 = center." Name="REGISTER_0x112_BIT7" References="TECHWELL TW8836 Data Sheet" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
    <CalID>_BHWQsCxpEeW8XK_nvVgh2w</CalID>
    <Type>Boolean</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
