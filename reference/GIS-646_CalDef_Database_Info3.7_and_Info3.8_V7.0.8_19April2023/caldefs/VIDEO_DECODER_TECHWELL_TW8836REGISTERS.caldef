      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>8</Value>
      <MinValue>0</MinValue>
      <MaxValue>15</MaxValue>
      <Resolution>1.0</Resolution>
