      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>1</Value>
      <MinValue>0</MinValue>
      <MaxValue>15</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="BT_656_ENCODE_CONTROL; Note as defined in the TW8836 data sheet: FUNCTION: ENCDITHER; DESCRIPTION: Enable BT.656 dither operation on. " Name="REGISTER_0x07C_BIT7" References="TECHWELL TW8836 Data Sheet" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
