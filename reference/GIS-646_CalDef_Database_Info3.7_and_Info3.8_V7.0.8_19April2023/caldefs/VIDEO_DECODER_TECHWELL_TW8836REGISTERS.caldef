      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="VERTICAL PEAKING CONTROL I ; Note as defined in the TW8836 data sheet: FUNCTION: SHCOR; DESCRIPTION: These bits provide coring function for the sharpness control." Name="REGISTER_0x117_BITS_7_thru_4" References="TECHWELL TW8836 Data Sheet" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
