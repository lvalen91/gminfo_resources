      <Value>3</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="When triggered, the user is prohibited from accessing the AppShop view. The feature restricted quick notice should be shown (reference GIS&#x2010;500)" Name="ServicePurchaseIntentFromOtherAppDriverWorkload" References="GIS 521 DRIVER WORKLOAD RESTRICTIONS OVERVIEW" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_EbSukLi2EeSxl78x5qydAw</CalID>
