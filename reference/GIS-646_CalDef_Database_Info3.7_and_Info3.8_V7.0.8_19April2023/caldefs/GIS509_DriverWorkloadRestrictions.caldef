      <Value>1</Value>
    </Enumeration>
  </CalDefinition>
  <CalDefinition Description="The user would not be able to open the Open Source screen when locked out. They would remain in the About view." Name="OpenSourceDriverWorkload" References="GIS 509 5.4.2.1*MY17 Driver Workload Restriction Items" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
