      <Version>1</Version>
      <Date>6/4/2021</Date>
      <Description>Initial Release of the calibration based on CR 2689912</Description>
      <Author>Greg Lindemann</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>300</Value>
      <MinValue>120</MinValue>
      <MaxValue>65353</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Calibration present in each ECU which supports SRU generation.  This calibration is used to enable/disable the entier SRU generateion funtion" Name="EnableSelfReportedUsageData" References="CR 2689912" Usage="MID,HIGH,GLOBALA,GLOBALB">
