  <CalDefinition Description="Calibration present in each ECU which supports SRU generation.  This calibration is used to configure the timespan of the activity counter increment interval." Name="ActivityCounterIncrementInterval" References="CR 2689912" Usage="MID,HIGH,GLOBALA,GLOBALB">
