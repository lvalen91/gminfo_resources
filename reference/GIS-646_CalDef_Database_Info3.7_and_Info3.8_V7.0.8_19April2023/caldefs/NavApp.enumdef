<?xml version="1.0" encoding="ASCII"?>
<enumdef:EnumDefinitionFile xmlns:enumdef="http://www.caltools.gm.com/enumdef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <EnumDefFileVersion>6</EnumDefFileVersion>
  <EnumDefFileChangeRecord>
    <Version>2</Version>
    <Date>13OCT14</Date>
    <Description>Removed invalid characters in EnumValue names and cleaned up names inorder to allow code generation.</Description>
    <Author>Scott Rush</Author>
  </EnumDefFileChangeRecord>
  <EnumDefFileChangeRecord>
    <Version>3</Version>
    <Date>8/13/2015</Date>
    <Description>Per request from Thiep Nguyen starting for MY18, updated the enumeration names referenced in the ECO_ROUTE_CURVE  CAL more generic versuses calling them out by specific vehicle names.</Description>
    <Author>Ginnard Kimbrough</Author>
  </EnumDefFileChangeRecord>
  <EnumDefFileChangeRecord>
    <Version>4</Version>
    <Date>4/11/2018</Date>
    <Description>Per CR# 1346230, added RANGE_PROJECTION_AND_SMART_ROUTING enumeration calibrations.</Description>
    <Author>Paul Wagner</Author>
  </EnumDefFileChangeRecord>
  <EnumDefFileChangeRecord>
    <Version>5</Version>
    <Date>03-21-2019</Date>
    <Description>Adding an enumeration for the following ENUM calibration HD_MAP_AND_ROUTE_TYPE</Description>
