  <EnumDefinition Description="Enum to define the types of Range Projection and Smart Routing." Name="RANGE_PROJECTION_AND_SMART_ROUTING">
    <EnumID>_3XGnwDnVEeefbJ5EEtYQTQ</EnumID>
