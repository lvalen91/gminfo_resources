  <CalDefinition Description="This calibration defines the high FM quality threshold to insert an FM Station in the Strong Station list." Name="FMQualHigh_In" References="GIS-653-2200 AM/FM Station List and Strong Station Lists " Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
    <CalID>_Kj9JUfiwEeOW_9IOenPZTA</CalID>
