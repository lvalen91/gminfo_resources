<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" CalDefCategory="Camera" Description="Defines Calibrations defined in GIS 942">
  <CalDefFileVersion>2</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>April 12 2018</Date>
    <Description>CR: 1577383 April 12 2018 Initial release of GIS942_AugmentedReality_GlobalB caldef</Description>
    <Author>Evelyn Job</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>Oct. 232018</Date>
    <Description>Per CR#1686594, updated min, max, resolution and default values for the following calibrations:  K_Augmented_Reality_Camera_Focal_x;  K_Augmented_Reality_Camera_Focal_y;  K_Augmented_Reality_Camera_Principle_Point_x;  K_Augmented_Reality_Camera_Principle_Point_y;  K_Augmented_Reality_Camera_Pitch;  K_Augmented_Reality_Camera_Translation_x;  K_Augmented_Reality_Camera_Translation_y;  K_Augmented_Reality_Camera_Translation_z were updated in GIS942_AugmentedReality_GlobalB.caldef file</Description>
    <Author>Evelyn Job</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="Calibration to turn on/off augmented reality display feature." Name="K_Augmented_Reality_Display_Enable" References="GIs-942" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_S9AZQDqFEeesh_Gsoan6Vg</CalID>
