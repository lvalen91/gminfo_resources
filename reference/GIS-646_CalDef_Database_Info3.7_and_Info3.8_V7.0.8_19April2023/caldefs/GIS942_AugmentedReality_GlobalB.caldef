    <Version>1</Version>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="Ability to turn off display of augmented reality when there is no navigation route (free drive)" Name="K_Augmented_Reality_Shown_In_Free_Drive" References="GIS-942" Usage="MID,HIGH,GLOBALB,VCU">
