  <CalDefinition Description="The SXMFastSeekRate calibration is used to define the rate the tuner will traverse through the available SXM channels during a user Press/Hold event.  The default value is 10 channels/second." Name="SXM_FastSeekRate" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_JLZyYTRCEeS02-rXT2e8SA</CalID>
    <Type>Integer</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
