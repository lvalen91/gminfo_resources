    </CalDefChangeRecord>
    <Integer>
      <Value>10</Value>
      <MinValue>5</MinValue>
      <MaxValue>20</MaxValue>
      <Units>none</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="This calibration is used to enable/disable the SXM Sports Flash feature in the tuner and the HMI display information associated with this feature.  When set to TRUE, the tuner shall enable Sports Flash and associated HMI display item(s). When set to FALSE, the tuner shall disable Sports Flash and the associated HMI display item(s).  The default state is TRUE." Name="SportsFlashActive" References="" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
