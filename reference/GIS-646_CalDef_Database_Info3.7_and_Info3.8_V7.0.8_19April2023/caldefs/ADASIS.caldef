  <CalDefinition Description="see GDMPRS-1000. As defined in the GDMPRS-100: The map provider shall be able to send out two instances of an electronic horizon at one time, given the calibration parameter AHP_SecondHorizonParallelInstance=True. " Name="AHP_SecondHorizonParallelInstanceActive" References="GIS-628 Appendix B" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_7CSIML44EeO1CZP5M-nrYg</CalID>
    <Type>Boolean</Type>
