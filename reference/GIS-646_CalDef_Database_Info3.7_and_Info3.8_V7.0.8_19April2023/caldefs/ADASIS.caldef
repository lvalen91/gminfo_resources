    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="see GDMPRS-1000. As defined in the GDMPRS-100: While the first EH shall work with the standard offset resolution of 1m, the second instance shall cover a long horizon of more than 8096m by setting the offset resolution to AHP_SecondHorizonOffsetResolution a higher value such as 10,20,50 or 200m (default:100m). Note: The value range for this calibration is 0-200 meters, and the default value is 100 meters as defined in the GIS-628 Specification." Name="AHP_SecondHorizonOffsetResolution" References="GIS-628 Appendix B" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
    <CalID>_DDJnUL45EeO1CZP5M-nrYg</CalID>
    <Type>Integer</Type>
    <Version>4</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>2016-06-14</Date>
      <Description>Updated the units, minimum, maximum, default and resolution values for this calibration.  Second horizon offset resolution should be calibratable. Default setting is: 10s.</Description>
      <Author>Andreas Klein</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>2016-08-19</Date>
      <Description>Changed the units from km to meters, and updated the description to clarify that the units desired for this calibration should be in meters. With this update, also updated the resolution to 1 and updated the minimum, maximum, resolution, and default values to correspond to how this is defined in the GIS-628 Specification. Update the usage type from High to Mid and High.</Description>
      <Author>Andreas Klein</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>2017-06-02</Date>
      <Description>Updated usage field to support new &quot;Global A/B&quot; categorization in CalDef tool.</Description>
      <Author>Andreas Andrae</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>100</Value>
      <MinValue>0</MinValue>
      <MaxValue>200</MaxValue>
      <Units>m</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Minimum most probable path length, see Appendix B. The value range for this calibration is 200-800 meters, and the default value is 200 meters as defined in the GIS-628 Specification." Name="AHP_Content_MinMPPLength" References="GIS-628 Appendix B" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
