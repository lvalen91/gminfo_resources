  <CalDefinition Description="Configures transmission of vehicle position message in milliseconds, see table in GDMPRS-923" Name="AHP_Tx_Position_Message_Update_Interval" References="GIS-628 Appendix B" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
