      <Author>Xufang Zhao</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>12/1/2015</Date>
      <Description>Usage correction to remove Low Radio usage for this CAL.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>3/7/2016</Date>
      <Description>Changed the name of this CAL from CONFIDENCE_THRESHOLD_US_ENGLISH to EMBEDDED_CONFIDENCE_THRESHOLD_USENGLISH to also include the word EMBEDDED at the beginning of the CAL name to make it easier to distinquish between the embedded and new server speech recognition CALs being added within this caldef file for MY18. Also, updated some of the default values within this calibration array.</Description>
      <Author>Xufang Zhao</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>5/11/2018</Date>
      <Description>Updated default value for two index values (6 and 7) within this array.</Description>
