      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The purpose of the calibration is to enable the G Force Friction Circle Range Information for Off Road App Content. The unit for this calibratable value is gravity 'g'." Name="OFF_ROAD_APP_G_FORCE_FRICTION_CIRCLE_RANGE" References="Off Road App STS, Off Road App FNC" Usage="MID,HIGH,VCU,ENTRY_VCU,GLOBALB">
