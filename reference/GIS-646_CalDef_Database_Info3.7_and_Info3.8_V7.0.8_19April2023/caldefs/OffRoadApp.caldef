      <MinValue>-45</MinValue>
      <MaxValue>45</MaxValue>
      <Units>degrees</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The purpose of the calibration is to enable the Onboard Tire Inflate Deflate Assist information for Off Road App Content. When this calibration is set to True ($1) = Enabled, when set to False ($0) = Disabled. " Name="OFF_ROAD_APP_ONBOARD_TIRE_INFLATE_DEFLATE_ASSIST_ENABLE" References="Off Road App STS, Off Road App FNC" Usage="MID,HIGH,VCU,ENTRY_VCU,GLOBALB">
