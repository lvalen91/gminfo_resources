    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="The purpose of the calibration is to choose the vehicle body style enumeration for Off Road App Contents based on Vehicle Model Codes. $1 = SUT (Truck), or $0 = SUV" Name="OFF_ROAD_APP_VEHICLE_BODY_STYLE" References="Off Road App STS, Off Road App FNC" Usage="MID,HIGH,VCU,ENTRY_VCU,GLOBALB">
