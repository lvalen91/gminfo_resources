<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" CalDefCategory="Chime" Description="">
  <CalDefFileVersion>10</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>5/31/2016</Date>
    <Description>Initial release for modules implementing Standard Chime Producers as implemneted on CR  19.19.124.873829.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>9/16/2016</Date>
    <Description>Global B CR 20.20.130.829313 Removed Chime Event 174.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>10/21/2016</Date>
    <Description>MY19 Info 3 CR:  1218149 -- Removed Chime Event 174 triggered due to vehicle CR 829313.  Added Events 935, 936, 615, 937, 938, 617 due to vehicle CR 822377.  Removed events 105, 110, 115, 120 and added event 585 due to vehicle CR 1083521.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>12/7/2016</Date>
    <Description>Updated Cal Def file to include new chime event 110 to support Passive Safety CR 1237029 with the Type 2 Global B SBR Chime for meeting EU Regulation.  Category value for all Chime Events correctly set to 12 instread of 15 to align correctly with GIS-631.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>2/15/2017</Date>
    <Description>Updated Cal Def file to include new chime event 586 to support Active Safety CR 1239990.  Updated default values of Chime Events 575 and 580 as part of Active Safety CR 1239990.  </Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>23MAY2017</Date>
    <Description>Updated &quot;Usage&quot; field to support new &quot;Global A/Global B&quot; categorization.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>10/2/2017</Date>
    <Description>Within the GIS631_StandardChimeProd_db_GlobalB.caldef, added GEM usage to all of the calibrations within this caldef. Since all of these calibrations fell within the current criteria of requiring GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>8</Version>
    <Date>12/7/17</Date>
    <Description>Added the following new Chime IDs for GEM: 105, 585, 600, 610, 635, 725, 730, 735, 740, 745, 750, 775, 810, 820, 825, 830, 845, 915, 920, 935, 940, 970, 971, 975, 976, 995, 1030, 1045, 1050, 1085, 1090, 1095, 1100, 1115, 1180, 2048, 2050, 2055, 2060, 2065, 2070, 2075, 2080, 2085, 2090, 2095, 2100, 2105, 2110, 2115, 2120, 2125, 2130, 2135, 2140, 2145, 2150, 2160, 2165, 2200, 2205, 2215, 2220, 2225, 2230, 2235, 2240, 2245, 2250, 2255, 2260, 2265, 2270, 2275, 2280, 2285, 2290, 2295</Description>
    <Author>Tanzima Mushtarin</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>9</Version>
    <Date>15FEB2018</Date>
    <Description>Per CR 1629546 updates to the following Chime IDs: 225, 230, 235, 240, 245, 250, 255, 260, 265, 270, 275, 280, 285, 290, 295, 300, 305, 310</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>10</Version>
    <Date>24May2018</Date>
    <Description>CR 1716684 : Changes to the ID's - 205,320, 325,330,335,340,360,365,370,375,380,400,405,410,415,420,440,445,450,455,460,480,485,490,495,500,520,525,530,535,540,</Description>
    <Author>Srikanth Kolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>11</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>12</Version>
    <Date>Apirl 10, 2019</Date>
    <Description>CR 2051430 - Added new GEM ID's 2300,2305,2310,2320,2325,2330,2335,2340,2345,2450</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>13</Version>
    <Date>05/30/2019</Date>
    <Description>Change: ID 2325, 2330 -  Change to Beep 750 from Gong 750 - Typo Error</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>14</Version>
    <Date>10/31/2019</Date>
    <Description>Corrected the Error: ID 175 - Chime Seperation, Repeating count, Tone and Pulse time</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>15</Version>
    <Date>11/1/2019</Date>
    <Description>Update to ID: 583 (Rear Pedestrian Notify) and Addition of New ID : 587 (Trailering phase I), ID 177: CHange in the Seperation and Repetion. </Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="String up to 255 characters providing versioning information about the theme." Name="K_STD_THEME_VERSION" Usage="LOW,GEM,GLOBALB,ENTRY_VCU">
