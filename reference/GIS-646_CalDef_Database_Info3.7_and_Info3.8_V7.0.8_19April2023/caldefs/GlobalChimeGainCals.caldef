    </Float>
  </CalDefinition>
  <CalDefinition Description="The chime producer module shall implement a boost/cut calibration for the beep and gong chime sounds within the Audio block that shall be applied as an offset to the ChimeSinkVolume signal." Name="BEEP_750_CHIME_GAIN" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
