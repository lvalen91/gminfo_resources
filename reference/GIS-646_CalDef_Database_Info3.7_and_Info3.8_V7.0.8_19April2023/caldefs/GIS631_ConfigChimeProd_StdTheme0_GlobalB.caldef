<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" CalDefCategory="Chime" Description="">
  <CalDefFileVersion>12</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>5/31/2016</Date>
    <Description>Restructuring of caldef file based on development CRs for Global B Chime Producer requirements.  New CalIDs assigned for each chime event as well as reforming of sound tone cal IDs.  Work done as part of MY19 Global B CR 19.19.120.761808.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>10/21/2016</Date>
    <Description>MY19 Info 3 CR:  1218149 -- Removed Chime Event 174 triggered due to vehicle CR 829313.  Added Events 935, 936, 615, 937, 938, 617 due to vehicle CR 822377.  Removed events 105, 110, 115, 120 and added event 585 due to vehicle CR 1083521.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>12/7/2016</Date>
    <Description>Updated Cal Def file to include new chime event 110 to support Passive Safety CR 1237029 with the Type 2 Global B SBR Chime for meeting EU Regulation.  Category value for all Chime Events correctly set to 12 instread of 15 to align correctly with GIS-631.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>2/15/2017</Date>
    <Description>Updated Cal Def file to include new chime event 586 to support Active Safety CR 1239990.  Updated default values of Chime Events 575 and 580 as part of Active Safety CR 1239990.  </Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>17APR2017</Date>
    <Description>Updated all Chime Event cals to reflect new chime theme audio files.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>23MAY2017</Date>
    <Description>Updated &quot;Usage&quot; field to support new &quot;Global A/Global B&quot; categorization.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>8</Version>
    <Date>05Jan2018</Date>
    <Description>Updated sound files per CR 1629546 ChimeIDs: 140, 142, 165, 170, 175, 176, 177, 178, 179, 180, 181, 186, 189, 190, 561, 565, 566, 570, 571, 576, 585, 586, 608, 615, 617, 710, 711, 712, 713, 721, 722, 723, 771, 774, 777, 778, 779, 782, 783, 785, 786, 788, 789, 791, 792, 794, 795, 797, 798, 800, 801, 935, 936, 937, 938</Description>
    <Author>Srikanth Kolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>9</Version>
    <Date>15FEB2018</Date>
    <Description>Per CR 1629546 updated the following Chime IDs: 225, 230, 235, 240, 245, 250, 255, 260, 265, 270, 275, 280, 285, 290, 295, 300, 305, 310</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>10</Version>
    <Date>24SEP2018</Date>
    <Description>CR 1989150 : Changes to the ID's - 320,325,330,335,340,360,365,370,375,380,400,405,410,415,420,440,445,450,455,460,480,485,490,495,500,520,525,530,535,540</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>11</Version>
    <Date>29OCT2018</Date>
    <Description>Per CR#: 1989150 GIS631_ConfigChimeProd_StdTheme0_GlobalB.caldef file : Changes to the ID's - 320,325,330,335,340,360,365,370,375,380,400,405,410,415,420,440,445,450,455,460,480,485,490,495,500,520,525,530,535,540 (Corrected Chime Seperation from Version 10)</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>12</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>13</Version>
    <Date>11/1/2019</Date>
    <Description>CR 2174482 - Adding Chime ID 587 (Trailering Phase 1), Update to CHime ID 583, Change in 175, Change in ID 177</Description>
    <Author>SKolachalama</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>14</Version>
    <Date>12/4/2020</Date>
    <Description>CR 2815512: New Chime IDs added for Drowsy Driver - Chime IDs  146 and 147; CR 2898441 - Change IDs 566, 571 (Rep= 1 and wave file = IP CLUSTER_2 and Separation = 0; CR 2791776 (TSM)- Added 2 new Chime IDs 588 and 589 </Description>
    <Author>Tanzima Mushtarin</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="String up to 255 characters providing versioning information about the theme." Name="K_THEME_0_VERSION" Usage="LOW,MID,HIGH,ENTRY_VCU,VCU">
