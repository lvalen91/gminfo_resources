    </CalDefChangeRecord>
    <String>
      <Encoding>UTF8</Encoding>
      <MaxLength>255</MaxLength>
      <StringValue>20.20.138</StringValue>
    </String>
  </CalDefinition>
  <CalDefinition Description="A Calibration that specifies the overall amplitude offset to apply when playing any chime event from the prescribed theme.  " Name="K_THEME_0_LEVEL_OFFSET" Usage="LOW,MID,HIGH,ENTRY_VCU,VCU">
