  <CalDefinition Description="SMART TOW FEATURE ON/OFF    (three buttons: standard guidelines, single guideline and hitch view button)" Name="RVS_FEATURE_AVAIL_SMART_TOW" References="GIS 40A" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_8UVeYCylEeaQhflu2B0O3Q</CalID>
    <Type>Enumeration</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>June 13, 2016</Date>
      <Description>Initial release of this enumeration cal beause needed to delete the existing RVS_FEATURE_AVAIL_SMART_TOW enumeration CAL with Cal ID(_g3XiccAEEeO0R63G0HVPeg) because it was incorrectly being linked to the enumeration for the RVS_FEATURE_AVAIL_GUIDELINES, therefore, needed to delete this existing calibration and create a this new RVS_FEATURE_AVAIL_SMART_TOW enumeration CAL (Cal ID:_8UVeYCylEeaQhflu2B0O3Q)) to link it to a new RVS_FEATURE_AVAIL_SMART_TOW enumeration that needed to be added to the FrontRearCameraStatic.enumdef file with the possible enumeration options for this calibration to match the possible enuumeration options that were already being shown for this calibration in the GIS-040. Also, calibration description update only for the RVS_TEXT_LOCATION calibration to just clarify what the possible values that already shown in the GIS-040 are intended to represent for this calibration.</Description>
      <Author>Evelyn Job</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/9/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date> 9/30/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>Dec. 7 2017</Date>
      <Description>added to the description: enables RPO PZ8 (three buttons: standard guidelines, single guideline and hitch view button)</Description>
      <Author>Evelyn Job</Author>
    </CalDefChangeRecord>
    <Enumeration>
      <EnumID>_wcwSACwZEeaQhflu2B0O3Q</EnumID>
      <Value>0</Value>
    </Enumeration>
  </CalDefinition>
