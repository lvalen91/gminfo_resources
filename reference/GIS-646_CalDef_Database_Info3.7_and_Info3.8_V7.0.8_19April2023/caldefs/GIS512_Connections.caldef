  <CalDefinition Description="User will not be able to enter the Keyboard view to rename Wi-Fi Network while vehicle is in motion" Name="VehicleWifiNameDriverWorkload" References="GIS 512 5.5.1.1*MY17 Driver Workload Restriction Items" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
