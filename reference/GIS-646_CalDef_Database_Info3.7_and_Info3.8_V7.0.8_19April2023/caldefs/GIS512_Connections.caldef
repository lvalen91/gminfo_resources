  <CalDefinition Description="User will not be able to enter the Keyboard view to change Wi-Fi Password while vehicle is in motion." Name="VehicleWiFiPasswordDriverWorkload" References="GIS 512 5.5.1.1*MY17 Driver Workload Restriction Items" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_9d6XobizEeSxl78x5qydAw</CalID>
