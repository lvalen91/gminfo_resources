    </Boolean>
  </CalDefinition>
  <CalDefinition Description="An icon will be displayed to indicate the signal strength. The icon will have six different states ranging from level 0 for no reception to level 5 for maximum reception." Name="EnablePhoneStatusRegionSignalStrength" References="5.1.1.1*MY17 Calibration Items" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
