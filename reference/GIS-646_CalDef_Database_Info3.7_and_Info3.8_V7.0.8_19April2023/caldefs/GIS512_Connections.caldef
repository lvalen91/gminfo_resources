  <CalDefinition Description="User shall not be able to initiate Bluetooth pairing process by holding their device to NFC antenna while vehicle is in motion." Name="NFCPairingDriverWorkload" References="GIS 512 5.5.1.1*Driver Workload Restriction Items" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
