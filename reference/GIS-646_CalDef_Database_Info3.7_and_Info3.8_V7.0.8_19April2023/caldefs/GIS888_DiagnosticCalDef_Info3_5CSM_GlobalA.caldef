      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="B248A_02_Wifi Antenna Circuit - This sub type is used for failures where the ECU measures ground (battery negative) potential for greater than a specified time period or when some other value is expected." Name="DTC_MASK_B248A_02" References="GIS-888" Usage="MID,HIGH,GLOBALA,VCU">
