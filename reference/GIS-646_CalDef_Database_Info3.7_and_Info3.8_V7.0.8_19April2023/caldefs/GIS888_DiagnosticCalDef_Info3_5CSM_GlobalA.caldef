<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" Description="Includes diagnostic related calibrations specific only to the GIS-888 for the CSM, and not applicable at all to either the GIS-621 or GIS-641.">
