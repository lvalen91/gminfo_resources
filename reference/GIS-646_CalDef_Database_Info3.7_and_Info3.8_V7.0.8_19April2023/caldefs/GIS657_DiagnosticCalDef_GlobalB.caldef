  <CalDefinition Description="Debounce Time shall be 2.5 Times the Timeout (timeout is 2.5 times the nominal periodic rate of the signal." Name="GIS657_DEBOUNCE_TIME" References="GIS-657" Usage="LOW,GEM,GLOBALB,ENTRY_VCU">
    <CalID>_1Q5AkEF8EeaX676o0O3GfQ</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/18/2017</Date>
      <Description>Added usage of GEM for this calibration.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>2500</Value>
      <MinValue>0</MinValue>
      <MaxValue>10000</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
