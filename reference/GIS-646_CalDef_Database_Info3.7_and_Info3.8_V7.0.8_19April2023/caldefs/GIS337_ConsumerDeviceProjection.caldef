  <CalDefinition Description="Enable CarPlay location Services. Value is set to be true by default.  When this calibration is set to True, it means that  location shall be shared with CarPlay. Otherwise when this calibration is set to False, Location shall not be set to CarPlay. (Note: This calibration is currently only needed for the F-Ten Info3 Low Radio supplier) " Name="Apple_CarPlay_Location" References="GIS 337-4100, added from CR 1635297" Usage="LOW,GLOBALA,GLOBALB,ENTRY_VCU">
    <CalID>_kxu2EMu3EeeTONb8lpYsfA</CalID>
    <Type>Boolean</Type>
    <Version>1</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>11/17/2017</Date>
      <Description>Initial release of this calibration</Description>
      <Author>Shanmukh Kandala</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="Enables connectivity of an Android Auto Client and Server over wireless (Wi-Fi and BT), and also enables Wireless Android Auto feature and related HMI menu items." Name="AndroidAuto_enableWireless" References="GIS-337" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_VcEOEE78Eeep_Namk9CiEQ</CalID>
    <Type>Boolean</Type>
