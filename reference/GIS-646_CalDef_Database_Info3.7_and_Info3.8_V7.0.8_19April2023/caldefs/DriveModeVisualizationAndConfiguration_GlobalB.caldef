  </CalDefinition>
  <CalDefinition Description="This calibration controls the timing on the Touch zone highlights. MY 21. Mid / High Radio. Global B" Name="TouchZonesHighlight_Time" References="GIS-552 5.1.1.1 MY21 Calibration Items" Usage="MID,HIGH,GLOBALB,VCU">
