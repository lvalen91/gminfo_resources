  <CalDefinition Description="The CSM and Low radio shall implement the LOUDNESS_OFFSET calibration within their ALC process to adjust loudness curves after sound tuning into the optimal position.  As an example, in the table in the previous section, the -20dB row represents the frequency response for 82dB(A) sound pressure level on the driver seat, head position.   If corrections are needed, the LOUDNESS_OFFSET calibration should be used to move the curve into the right position. The LOUDNESS_OFFSET calibration is defined in the DistortionLimiting.caldef file within GIS-646 with Range of -20dB ... +20dB  (1dB Steps)  and a default value of 0dB." Name="LOUDNESS_OFFSET" References="GIS-604-547" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_BUk-MDLQEeSm0acW-cA1AQ</CalID>
    <Type>Integer</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>9/30/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>0</Value>
      <MinValue>-20</MinValue>
      <MaxValue>20</MaxValue>
      <Units>dB</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="Enables / disables Automatic Loudness Compensation processing.   True = Enabled, False = Disabled" Name="LOUDNESS_COMP_ENABLE" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_87iC8EWqEeSJbrP6o-dHmQ</CalID>
    <Type>Boolean</Type>
    <Version>2</Version>
    <CalDefChangeRecord>
