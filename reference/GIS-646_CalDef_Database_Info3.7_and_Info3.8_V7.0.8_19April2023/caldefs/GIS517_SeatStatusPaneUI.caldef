  <CalDefinition Description="When enabled, user is prohibited from interacting with the seat status pane. The massage on off toggle will still function. The CSM will respond to system as if Display Active = False" Name="SeatStatusPaneLockoutDriverWorkload" References="5.5.1.1*MY17 Driver Workload Restriction Items" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
