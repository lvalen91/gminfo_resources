      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>5</Value>
      <MinValue>0</MinValue>
      <MaxValue>60</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The dwell time for a welcome message when switching users." Name="Welcome_Message_Switching_Users" References="GIS-508 5.1.1.1*MY17" Usage="MID,HIGH,GLOBALA,GLOBALB,VCU">
