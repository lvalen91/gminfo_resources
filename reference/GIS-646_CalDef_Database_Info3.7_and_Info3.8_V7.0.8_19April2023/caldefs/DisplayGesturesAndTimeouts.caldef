      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>2/26/2016</Date>
      <Description>Updated the default value for this CAL from 250 to 50. Based off of feedback received from Cody Hansen that this is the most optimal value to set this value to at this point.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
