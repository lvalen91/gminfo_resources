  <CalDefinition Description="This defines the minimum number of volume positions that must be detected before it qualifies the action as a swipe/fling of the faceplate volume." Name="FACEPLATE_FLING_MIN_VOLUME_POSITIONS" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
