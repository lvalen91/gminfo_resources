  <CalDefinition Description="Time for how long buttons on Alerts and Pop-ups should be delayed before being presented to prevent the user from inadvertently dismissing the pop-up unintentionally. The default time is 500ms." Name="ALERTWINDOWELEMENT_DELAYEDACTIONPRESENTATIONTIME" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ypCmk01AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
    <Version>5</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_display_interface_caln</Description>
      <Author>GIS-344 GIS-343</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>1/13/2017</Date>
      <Description>Updated the units for the ALERTWINDOWELEMENT_DELAYEDACTIONPRESENTATIONTIME  calibration from none to miliseconds to reflect the units that was always defined for this calibration in the GIS-500.</Description>
      <Author>Ginnard Kimbrough</Author>
