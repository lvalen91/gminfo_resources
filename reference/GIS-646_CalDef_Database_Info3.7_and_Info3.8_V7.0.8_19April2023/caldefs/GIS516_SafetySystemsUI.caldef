  <CalDefinition Description="For vehicles with trailering packages, the camera app will timeout and close after a number of seconds" Name="TrailerViewTimeout" References="GIS-516 5.1.1.1*MY17" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
