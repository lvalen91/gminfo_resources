  <CalDefinition Description="For vehicles with trailering packages, the camera app will only open when it reaches a certain vehicle speed." Name="OverspeedValueTruck" References="GIS-516 5.1.1.1*MY17" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
