  <CalDefinition Description="When InfotainmentSoftButton4Visible (Value 13 [Section FU-014-6 Indications] ) is set to false (invalid), the exit park feature will not be available on that vehicle and the Departure tab will not be shown." Name="ExitParkAvailability" References="GIS-516 5.1.1.1*MY17" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ozUIwG8xEeSP1-yKskOqPA</CalID>
