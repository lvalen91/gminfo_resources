  <CalDefinition Description="The amount of time in between &quot;IPC+ICS PIXEL Refresher update&quot; procedures. " Name="PIXEL_REFRESHER_TIMING" References="GIS1007 Section 5.1" Usage="MID,HIGH,GLOBALB,VCU">
    <CalID>_XBvhkLeDEei_I8fAcof7OA</CalID>
    <Type>Integer</Type>
