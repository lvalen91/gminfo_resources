<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" Description="">
  <CalDefFileVersion>3</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>05/01/2018</Date>
    <Description>Per CR# 1775795, adding GIS1007_Settings_GlobalB.caldef file to document calibrations pertaining to the GIS-1007.</Description>
    <Author>Emmanuel Oleka</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>09/17/2018</Date>
    <Description>Per CR#1912236, removed Help Cal from GIS1007_Settings_GlobalB.caldef, and added Help Cal redefined as EnumIntegerMap GIS1000_FrameworksWidgets.caldef and renamed P_DISPLAY_UNIT_MENU. Per CR#1912236, Updated GIS1007_Settings_GlobalB.caldef with added calibrations: PIXEL_REFRESHER_MENU, PIXEL_REFRESHER_TIMING, PIXEL_REFRESHER_TIMING_UNIT, RADIO_SCREEN_SAVER_TIME, RADIO_SCREEN_SAVER_TIME_UNIT, OPEN_SOURCE_SOFTWARE_RADIO, and TIRE_LOAD_TIMEOUT. Updated GIS1007_Settings_GlobalB.enumdef with added enumerations: PIXEL_REFRESHER_TIMING_UNIT and RADIO_SCREEN_SAVER_TIME_UNIT enums. </Description>
    <Author>Ibnul Khan</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
