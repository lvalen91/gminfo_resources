    <Integer>
      <Value>30</Value>
      <MinValue>1</MinValue>
      <MaxValue>400</MaxValue>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description=" For every calibratable amount of time(PIXEL_REFRESER_TIMING) IPC/ICS display needs Pixel refreshed. Cal Used to show menu item in the settings limit, $TRUE = ON and $False = Off" Name="PIXEL_REFRESHER_MENU" References="GIS1007 Section 5.1" Usage="MID,HIGH,GLOBALB,VCU">
