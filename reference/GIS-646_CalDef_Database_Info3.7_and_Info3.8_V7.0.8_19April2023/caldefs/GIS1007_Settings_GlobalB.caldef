  <CalDefinition Description="For some markets, &#x201c;Time, Date, and Unit menu&#x201d; will be shown as &#x201c;Time and Date&#x201d;. And Unit menu will not be displayed. Note: False= Menu Off; True= Menu ON" Name="P_DISPLAY_UNIT_MENU_PRESENT" References="GIS-1007 Section 5.1 calibrations" Usage="MID,HIGH,GLOBALB,VCU">
