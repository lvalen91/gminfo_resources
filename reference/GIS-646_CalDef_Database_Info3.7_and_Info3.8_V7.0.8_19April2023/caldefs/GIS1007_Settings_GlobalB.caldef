  <CalDefinition Description="For some markets, customers cannot disable Speed Sign in HUD, when this cal is set to 0, hide Speed Sign option from Head Up Display Contents menu. Note: False=Radio Button Unavailable; True= Radio Button Available" Name="P_HUD_SPEED_SIGN_MENU_PRESENT" References="GIS-1007 Section 5.1 calibrations" Usage="MID,HIGH,GLOBALB,VCU">
