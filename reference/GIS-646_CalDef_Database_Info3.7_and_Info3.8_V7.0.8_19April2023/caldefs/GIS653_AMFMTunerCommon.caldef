  </CalDefinition>
  <CalDefinition Description="This calibration defines the total timing (cycle time) of the muting process in msec.  The default value is 50msec." Name="FaderPeriod" References="" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ypiV2k1AEeO3UM5MzM17kw</CalID>
    <Type>Float</Type>
    <Version>4</Version>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>10/2/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Float>
      <Value>50.0</Value>
      <MinValue>0.0</MinValue>
      <MaxValue>2000.0</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>0.1</Resolution>
    </Float>
  </CalDefinition>
  <CalDefinition Description="After switching off the antenna in case of overcurrent protection the antenna supply is switches on again within an AntennaFailRecheckInterval which could by calibrated by CAL_AntennaFailRecheckInterval." Name="AntennaFailCheckInterval" References="" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ypi84E1AEeO3UM5MzM17kw</CalID>
    <Type>Integer</Type>
