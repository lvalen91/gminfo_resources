  <CalDefinition Description="After switching off the antenna in case of overcurrent protection, the antenna supply shall switch back on again within an antenna fail recheck interval.  This interval shall be set by the cal_DABAntennaFailCheckInterval defined in the DABTuner.caldef file in GIS-646. " Name="DAB_DABAntennaFailCheckInterval" References="GIS-313-1300 Active Antenna Power Supply (Phantom supply)" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_uky4cNL4EeSPn-nUOvTPiQ</CalID>
    <Type>Integer</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
