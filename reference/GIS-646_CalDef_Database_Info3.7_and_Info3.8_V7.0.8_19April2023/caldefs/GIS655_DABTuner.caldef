      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Integer>
      <Value>10</Value>
      <MinValue>5</MinValue>
      <MaxValue>30</MaxValue>
      <Units>seconds</Units>
      <Resolution>1.0</Resolution>
    </Integer>
  </CalDefinition>
  <CalDefinition Description="The following parameters define the FIC-EFC (or FIC-BIR) which has to be reached to judge &#x2018;sufficient DAB signal available&#x2019; in DAB software. It shall be used for any kind of seeking to ultimately add an ensemble to a station list.  A calibration defined as CAL_SeekStopBIII shall be used to define Tuning Stop Sensitivity." Name="DAB_SeekStopBIII" References="GIS-313-1510 Tuning Stop Sensitivity" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_q-N94NL5EeSPn-nUOvTPiQ</CalID>
    <Type>Float</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>Dec. 06, 2016</Date>
      <Description>Changed default value to 50.999 based on Harman recommendation.</Description>
      <Author>Christian Gro&#xdf;</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/2/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Float>
      <Value>50.999</Value>
      <MinValue>5.0</MinValue>
      <MaxValue>255.0</MaxValue>
      <Units>none</Units>
      <Resolution>0.001</Resolution>
    </Float>
  </CalDefinition>
  <CalDefinition Description="The DAB_FastSeekTuneRate is a combined Seek/Tune cal that defines the Fast Seek/Tune Rate in steps per second for DAB tuning operations. This calibration is used when the User executes an DAB Fast Seek/Tune operation. The default value is 3 steps/sec." Name="DAB_FastSeekTuneRate" References="" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
