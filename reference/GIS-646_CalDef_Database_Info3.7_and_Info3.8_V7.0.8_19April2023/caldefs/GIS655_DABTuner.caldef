  <CalDefinition Description="The minimal time after exceeding the DABDABLink_DABWeakThreshold before starting the DAB search algorithm." Name="DAB_DAB_LinkDABSearchStartTime" References="GIS-699-032005 Seamless DAB-DAB Linking under weak signal / No signal condition" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU">
    <CalID>_ypkLAU1AEeO3UM5MzM17kw</CalID>
    <Type>Float</Type>
    <Version>4</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>2/26/2015</Date>
      <Description>Confirmed with Alan Budyta the max value of this cal should be changed from 255 to 3500. Now the default value fits within the cal range.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>26.05.2015</Date>
      <Description>Changed usage to LOW as this parameter is only applicable in single tuner designs.</Description>
      <Author>Christian Gro&#xdf;</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
