      <Version>3</Version>
      <Date>10/2/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="The DAB_FM_LinkingActive cal defines whether DAB to FM linking shall be enabled in the tuner and whether or not the associated HMI menu item(s) associated with this feature should be displayed. TRUE means enable DAB to FM linking in the tuner and display the associated DAB to FM Linking menu item(s). FALSE means disable DAB to FM linking in the tuner and disable HMI display of the associated DAB to FM Linking menu item(s). The default value is TRUE. The tuner shall also take appropriate action to support/not support the processing of this feature based on the cal setting. This helps balance and optimize system resources based on activated features for a given market." Name="DAB_FM_LinkingActive" References="GIS-699-031900 DAB Default Settings" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_5AkQQScAEeSmb8tw1ZVRMw</CalID>
    <Type>Boolean</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>6/15/2017</Date>
      <Description>Updated the usage field for this calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>10/2/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>true</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="The DAB_AnnouncementsActive cal defines whether the HMI menu items associated with DAB Announcements and the associated tuner processing should be enabled/disabled for a specific region. TRUE means display the DAB announcements HMI menu item(s) and activate DAB announcement processing in the Tuner. FALSE means do not display the DAB announcements HMI menu item(s) and do not activate DAB announcement processing in the tuner. The default value is TRUE. This helps balance and optimize system resources based on features activated for a given market." Name="DAB_AnnouncementsActive" References="GIS-699-031900 DAB Default Settings" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_v_sEcSbmEeSmb8tw1ZVRMw</CalID>
