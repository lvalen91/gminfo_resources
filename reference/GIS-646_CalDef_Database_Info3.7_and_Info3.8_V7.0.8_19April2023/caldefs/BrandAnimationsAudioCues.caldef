      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>4</Version>
      <Date>1/13/2017</Date>
      <Description>Changed the name of the AUDIO_CUE_ACUE_STOP calibration to AUDIO_CUE_ACUE_STOP_ENABLED, and updated the description of this calibration to match how this calibration is defined in the latest version GIS-500. </Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>5</Version>
      <Date>9/29/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="CueCalibrations [CueType] These are the boolean calibration flags for each of the cues defined within the AudioCues Fblock. There are currently 11 Cues defined. The CueType takes values from 0x01 - 0x0B.&#xA;&#xA;The diagram below defines the processing within the AudioCue FBlock for generating AudioCues relative to vehicle and system state changes&#xA;&#xA;All vehicles will have a Welcome Animation&#xA;Only Hybrid vehicles would have Startup/Run and Shutdown/Goodbye AudioCues enabled.  " Name="AUDIO_CUE_SHUTDOWN_ENABLE" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ypM-o01AEeO3UM5MzM17kw</CalID>
    <Type>Boolean</Type>
    <Version>3</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
      <Date>26AUG2013</Date>
      <Description>Initial import on from GIS-344 derived CSV file.  Original CALDS block=hmi_navn_map_database_graphics_caln</Description>
      <Author>GIS-500</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>2</Version>
      <Date>4/20/2015</Date>
      <Description>Per agreement with Sanghyun Ryu updated AUDIO_CUE_SHUTDOWN_ENABLE cal to include usage of Low Radio.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>3</Version>
      <Date>9/29/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <Boolean>
      <Value>false</Value>
    </Boolean>
  </CalDefinition>
  <CalDefinition Description="CueCalibrations [CueType] These are the boolean calibration flags for each of the cues defined within the AudioCues Fblock. There are currently 11 Cues defined. The CueType takes values from 0x01 - 0x0B.&#xA;&#xA;The diagram below defines the processing within the AudioCue FBlock for generating AudioCues relative to vehicle and system state changes&#xA;&#xA;All vehicles will have a Welcome Animation&#xA;Only Hybrid vehicles would have Startup/Run and Shutdown/Goodbye AudioCues enabled.  " Name="AUDIO_CUE_STARTUP_ENABLE" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ypM-pE1AEeO3UM5MzM17kw</CalID>
