  <CalDefinition Description="Shutdown Animation type&#xA;The shutdown animation shall be defined by a calibration setting as shown below&#xA;" Name="VEHICLE_ANIMATION_SHUTDOWN_TYPE" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
