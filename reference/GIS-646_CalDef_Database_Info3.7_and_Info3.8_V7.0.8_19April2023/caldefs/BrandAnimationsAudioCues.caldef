  <CalDefinition Description="Start-up Audio Cues type&#xA;The Start-up Audio Cues shall be defined by a calibration setting as shown below&#xA;" Name="VEHICLE_AUDIOCUE_STARTUP_TYPE" References="GIS-500" Usage="LOW,MID,HIGH,GEM,GLOBALA,GLOBALB,ENTRY_VCU,VCU">
    <CalID>_ysMBNE1AEeO3UM5MzM17kw</CalID>
    <Type>Enumeration</Type>
    <Version>4</Version>
    <CalDefChangeRecord>
      <Version>1</Version>
