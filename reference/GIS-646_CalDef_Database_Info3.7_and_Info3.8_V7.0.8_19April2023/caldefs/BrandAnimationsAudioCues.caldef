    <CalDefChangeRecord>
      <Version>5</Version>
      <Date>1/13/2017</Date>
      <Description>Updated the calibration description and default value for the AUDIO_CUE_WELCOME_ENABLE calibration to correspond to how this is reflected in the latest version GIS-500.</Description>
      <Author>Ginnard Kimbrough</Author>
    </CalDefChangeRecord>
    <CalDefChangeRecord>
      <Version>6</Version>
      <Date>9/29/2017</Date>
      <Description>Updated vehicle architectural usage to add GEM usage for this calibration because it fell within the current criteria of calibrations that require GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
