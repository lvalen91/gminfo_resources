  <CalDefFileVersion>4</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>29SEP14</Date>
    <Description>Added Usage on MID and HIGH</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>6/14/2017</Date>
    <Description>Updated the usage field for all of the calibration in this caldef file to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="Initial timer used when the CSM makes a diagnostic request." Name="ADABaseTimer" Usage="MID,HIGH,GLOBALA,GLOBALB">
    <CalID>_z9rIgMyHEeOPiKIwrDE3eQ</CalID>
    <Type>Float</Type>
    <Version>1</Version>
    <Float>
      <Value>50.0</Value>
      <MinValue>0.0</MinValue>
      <MaxValue>255.0</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>100.0</Resolution>
    </Float>
  </CalDefinition>
  <CalDefinition Description="Timer used when the CSM has made a diagnostic request and receives a response of either the first frame of a multi-frame message, the first UUDT response, or a GMLAN = $7F $xx $78 response, or the first flow control message. " Name="ADALongTimer" Usage="MID,HIGH,GLOBALA,GLOBALB">
    <CalID>_6hwEEMyIEeOPiKIwrDE3eQ</CalID>
    <Type>Float</Type>
    <Version>1</Version>
    <Float>
      <Value>147.0</Value>
      <MinValue>0.0</MinValue>
      <MaxValue>255.0</MaxValue>
      <Units>milliseconds</Units>
      <Resolution>100.0</Resolution>
    </Float>
  </CalDefinition>
