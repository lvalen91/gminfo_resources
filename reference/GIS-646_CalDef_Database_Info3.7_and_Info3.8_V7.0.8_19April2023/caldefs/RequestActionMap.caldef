  <CalDefinition Description="Action Map for Active Stream Type of STREAM_BLUETOOTH_SCO" Name="STREAM_BLUETOOTH_SCO" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU,MID,HIGH,VCU">
    <CalID>_jkeNIK3VEeOe_uWRKKMYzg</CalID>
