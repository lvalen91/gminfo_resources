<?xml version="1.0" encoding="ASCII"?>
<caldef:CalDefinitionFile xmlns:caldef="http://www.caltools.gm.com/caldef" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Description="GIS-604-810 Audio Stream Request Management. The Request Action Map is only applicable for non-Android 9+ platforms.">
  <CalDefFileVersion>13</CalDefFileVersion>
  <CalDefFileChangeRecord>
    <Version>1</Version>
    <Date>17APR14</Date>
    <Description>Reviewed for compliance to CalDef Guidelines. - Jon G</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>2</Version>
    <Date>12SEPT2014</Date>
    <Description>Updates to audio stream Request Actions in the following streams to change request action from Suspend to Deny to support stock Android stream Music and 3rd party apps as tracked though assembla ticket 1145.  Update Request Actiosn in Mix Prompt streams to Grant_Deact for requesting stream TTS and Speech for OpenSL issue in Assembla ticket 989.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>3</Version>
    <Date>29SEP14</Date>
    <Description>Added Usage on LOW, MID, and HIGH</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>4</Version>
    <Date>10/31/2014</Date>
    <Description>Added new stream type &quot;STREAM_NATIVE_HFM_WB&quot; to support wide band bluetooth audio.  Part of Harman Assembla ticket 1223.  Re-Ordered Streams based on Harman Assembla ticket #1265</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>5</Version>
    <Date>11/17/2015</Date>
    <Description>Adjusted priorities of streams HFM, HFM_WB, MUTEX_PROMPT, DTCP_PROMPT, and DTCP_CALL.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>6</Version>
    <Date>12/18/2015</Date>
    <Description>Adjusted priorities of streams STREAM_BLUETOOTH_SCO, STREAM_NATIVE_ATCP_RING, STREAM_NATIVE_DTCP_CALL, STREAM_NATIVE_DTCP_PROMPT, STREAM_NATIVE_DTCP_RING, STREAM_NATIVE_HFM, STREAM_NATIVE_HFM_WB, STREAM_NATIVE_MUTEX_PROMPT, STREAM_NATIVE_PHN_VR, STREAM_NATIVE_RING, STREAM_NATIVE_SPEECH, STREAM_RING, and STREAM_VOICE_CALL to handle various OnStar Application audio issues. Also, updated priorities of streams HFM, HFM_WB, MUTEX_PROMPT, DTCP_PROMPT, and DTCP_CALL back to what it was originally prior to the updates made for this in version 5 of this caldef file. Also, added back in usage of Low Radio for all of the CALs within this caldef.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>7</Version>
    <Date>6/28/2016</Date>
    <Description>STREAM_NATIVE_DTCP_ECALL - Changed stream interaction default value between DTCP_ECALL and DTCP_ECALL to GRANT_CHANGE due to MY17 integration issues.  STREAM_NATIVE_ATCP_ECALL - Changed stream interaction default value between ATCP_ECALL and ATCP_ECALL to GRANT_CHANGE due to MY17 integration issues.  STREAM_NATIVE_DTCP_CALL - Changed stream interaction default value between VOICE_CALL, BLUETOOTH_SCO, NATIVE_HFM, and NATIVE_HFM_WB from DENY to GRANT_DEACT due to MY17 integration issues. Updated STREAM_VOICE_CALL with MUTEX_PROMPT to DENY, and with DTCP_PROMPT to GRANT_DEACT. Also, updated STREAM_BLUETOOTH_SCO with MUTEX_PROMPT to DENY, and with DTCP_PROMPT to GRANT_DEACT.</Description>
    <Author>Dominic Colella</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>8</Version>
    <Date>6/15/2017</Date>
    <Description>Updated the usage field for all of the calibration to support the new &quot;Global A/B&quot; categorization in the CalDef tool.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>9</Version>
    <Date>10/2/2017</Date>
    <Description>Added GEM usage to all of the calibrations in the RequestActionMap.caldef . Since all of these calibrations fell within the current criteria of requiring GEM usage, which are any calibrations that would be used for Low Radio Global B application.</Description>
    <Author>Ginnard Kimbrough</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>10</Version>
    <Date>9/11/2018</Date>
    <Description>CR1261915 - Added new stream type STREAM_NATIVE_PROJ_ALT_AUDIO  </Description>
    <Author>Christine Marzan</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>11</Version>
    <Date>27MAR2019</Date>
    <Description>Added 'ENTRY_VCU' and 'VCU' tags for initial creation of VCS compatible CalDefDatabase for version GIS-646 V6.0.0 release.</Description>
    <Author>Scott Rush</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>12</Version>
    <Date>6/6/2019</Date>
    <Description>CR2201070 - Updated values for STREAM_NATIVE_DTCP_ECALL &amp; STREAM_NATIVE_ATCP_ECALL &amp; for all other streams to comply with regulatory emergency call handling</Description>
    <Author>Christine Marzan</Author>
  </CalDefFileChangeRecord>
  <CalDefFileChangeRecord>
    <Version>13</Version>
    <Date>6/7/2019</Date>
    <Description>Per CR#2060763 AOSP transition, in MY22 GIS-646 Cal DB V6.0.3 remove MID/HIGH, VCU usage for all streams. Request Action Map does not apply to Android 9+ platforms.</Description>
    <Author>Christine Marzan</Author>
  </CalDefFileChangeRecord>
  <CalDefinition Description="Action Map for Active Stream Type of STREAM_VOICE_CALL" Name="STREAM_VOICE_CALL" Usage="LOW,GEM,GLOBALA,GLOBALB,ENTRY_VCU,MID,HIGH,VCU">
    <CalID>_jit5oK3VEeOe_uWRKKMYzg</CalID>
    <Type>Record</Type>
