  <CalDefinition Description="Action Map for Active Stream Type of STREAM_NATIVE_DTCP_ECALL" Name="STREAM_NATIVE_DTCP_ECALL" Usage="LOW,ENTRY_VCU,GEM,GLOBALA,GLOBALB,MID,HIGH,VCU">
    <CalID>_jtb74K3VEeOe_uWRKKMYzg</CalID>
